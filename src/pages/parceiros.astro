---
import BaseLayout from '../layouts/Base.astro';
import FloatingNavbar from '../components/navbar/FloatingNavbar.svelte';
import Footer from '../components/Footer.svelte';

const partners = [
  {
    slug: 'alice',
    name: 'Alice',
    logoMaskPath: '/images/logos_svgs/logo_alice_cropped.svg',
    logoWidth: 'min(100%, 16rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 18rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(206, 52%, 58%, 0.22)',
    panelGlowB: 'hsla(220, 58%, 11%, 0.28)',
    panelFrom: 'hsl(210, 34%, 34%)',
    panelMid: 'hsl(214, 38%, 25%)',
    panelTo: 'hsl(218, 44%, 18%)',
    panelBorder: 'hsla(210, 24%, 92%, 0.07)',
    reading: 'coordenação e jornada',
    focus: 'modelo assistencial',
  },
  {
    slug: 'porto',
    name: 'Porto',
    logoMaskPath: '/images/logos_svgs/logo_porto.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 24rem)',
    logoMaxHeightMobile: 'min(70%, 14rem)',
    panelGlowA: 'hsla(208, 34%, 48%, 0.12)',
    panelGlowB: 'hsla(220, 62%, 8%, 0.34)',
    panelFrom: 'hsl(212, 28%, 24%)',
    panelMid: 'hsl(215, 34%, 18%)',
    panelTo: 'hsl(220, 40%, 12%)',
    panelBorder: 'hsla(210, 18%, 88%, 0.05)',
    reading: 'rede ampla e estabilidade',
    focus: 'cobertura corporativa previsível',
  },
  {
    slug: 'bradesco',
    name: 'Bradesco',
    logoMaskPath: '/images/logos_svgs/logo_bradesco.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 21rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(206, 38%, 56%, 0.16)',
    panelGlowB: 'hsla(220, 52%, 10%, 0.28)',
    panelFrom: 'hsl(210, 30%, 30%)',
    panelMid: 'hsl(214, 34%, 22%)',
    panelTo: 'hsl(219, 38%, 16%)',
    panelBorder: 'hsla(210, 24%, 92%, 0.06)',
    reading: 'rede e previsibilidade',
    focus: 'capilaridade assistencial',
  },
  {
    slug: 'sulamerica',
    name: 'SulAmerica',
    logoMaskPath: '/images/logos_svgs/logo_sulamerica.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 22rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(198, 44%, 58%, 0.18)',
    panelGlowB: 'hsla(221, 56%, 11%, 0.26)',
    panelFrom: 'hsl(206, 34%, 34%)',
    panelMid: 'hsl(211, 37%, 25%)',
    panelTo: 'hsl(217, 43%, 18%)',
    panelBorder: 'hsla(208, 24%, 92%, 0.07)',
    reading: 'flexibilidade e desenho',
    focus: 'elegibilidade corporativa',
  },
  {
    slug: 'omint',
    name: 'Omint',
    logoMaskPath: '/images/logos_svgs/logo_omint.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 19rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(212, 32%, 50%, 0.12)',
    panelGlowB: 'hsla(222, 62%, 7%, 0.34)',
    panelFrom: 'hsl(216, 28%, 22%)',
    panelMid: 'hsl(220, 32%, 16%)',
    panelTo: 'hsl(224, 38%, 10%)',
    panelBorder: 'hsla(42, 18%, 82%, 0.06)',
    reading: 'padrão premium e rede',
    focus: 'cobertura executiva',
  },
  {
    slug: 'amil',
    name: 'Amil',
    logoMaskPath: '/images/logos_svgs/logo_amil.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 20rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(204, 40%, 60%, 0.16)',
    panelGlowB: 'hsla(220, 58%, 9%, 0.3)',
    panelFrom: 'hsl(208, 33%, 31%)',
    panelMid: 'hsl(213, 37%, 22%)',
    panelTo: 'hsl(218, 41%, 15%)',
    panelBorder: 'hsla(210, 26%, 92%, 0.06)',
    reading: 'capilaridade e acesso',
    focus: 'escala de cobertura',
  },
];

const partnerSections = partners.map((partner, index) => {
  const id = `parceiro-${partner.slug}`;
  const nextPartner = partners[index + 1];

  return {
    ...partner,
    id,
    detailId: `${id}-detalhes`,
    nextId: nextPartner ? `parceiro-${nextPartner.slug}` : null,
  };
});
---

<BaseLayout
  title="Parceiros | Klout"
  description="Conheça a rede de parceiros da Klout e como a curadoria especializada conecta seguradoras, empresas e clientes com mais eficiência."
  smoothScrollDelay={12000}
>
  <main id="main-content">
    <section
      id="parceiros"
      class="partners-page-hero"
      data-stack-section
      data-stack-end="185%"
    >
      <div class="partners-page-geo" aria-hidden="true">
        <div class="partners-page-geo-line partners-page-geo-line-v1"></div>
        <div class="partners-page-geo-line partners-page-geo-line-v2"></div>
        <div class="partners-page-geo-line partners-page-geo-line-v3"></div>
        <div class="partners-page-geo-line partners-page-geo-line-h1"></div>
        <div class="partners-page-geo-line partners-page-geo-line-h2"></div>
      </div>
      <div class="partners-page-hero-shell">
        <div class="partners-page-hero-copy">
          <h1 class="partners-page-hero-title">Rede de parcerias Klout</h1>
        </div>

        <div class="partners-page-hero-visual" aria-label="Mapa do Brasil com operadoras parceiras">
          <div class="partners-page-hero-map" aria-hidden="true"></div>

          <div class="partners-page-hero-node partners-page-hero-node-alice">
            <img src="/images/logos_svgs/logo_alice.svg" alt="Alice" class="partners-page-hero-node-logo partners-page-hero-node-logo-alice" loading="lazy" width="210" height="297" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-porto">
            <img src="/images/logos_svgs/logo_porto.svg" alt="Porto" class="partners-page-hero-node-logo partners-page-hero-node-logo-porto" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-bradesco">
            <img src="/images/logos_svgs/logo_bradesco.svg" alt="Bradesco" class="partners-page-hero-node-logo partners-page-hero-node-logo-bradesco" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-sulamerica">
            <img src="/images/logos_svgs/logo_sulamerica.svg" alt="SulAmerica" class="partners-page-hero-node-logo partners-page-hero-node-logo-sulamerica" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-omint">
            <img src="/images/logos_svgs/logo_omint.svg" alt="Omint" class="partners-page-hero-node-logo partners-page-hero-node-logo-omint" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-amil">
            <img src="/images/logos_svgs/logo_amil.svg" alt="Amil" class="partners-page-hero-node-logo partners-page-hero-node-logo-amil" loading="lazy" width="4096" height="4096" />
          </div>
        </div>

        <div class="partners-page-hero-rail">
          <div class="partners-page-hero-notes" aria-label="Diferenciais da rede de parcerias Klout">
            <p class="partners-page-hero-note">
              Operadoras rigorosamente selecionadas pela curadoria Klout
            </p>
            <p class="partners-page-hero-note">
              Acesso mais amplo a serviços médicos e melhores hospitais
            </p>
            <p class="partners-page-hero-note">
                Comparação feita para melhorar acesso sem inflar custo com benefícios que não serão usados
            </p>
          </div>

          <a
            href="#parceiro-alice"
            class="partners-page-hero-cta control-button"
            aria-label="Ir para a primeira operadora"
          >
            <span class="control-button__arrow control-button__arrow--right" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    </section>

    {partnerSections.map((partner) => (
      <section
        id={partner.id}
        class="partner-stage-section"
        data-stack-section
        data-stack-end="220%"
      >
        <div class="partner-stage-veil" aria-hidden="true"></div>
        <div class="partner-stage-track">
          <article class="partner-stage-panel partner-stage-panel-hero">
            <div class="partner-hero-shell">
              <div
                class="partner-hero-panel"
                style={`--partner-logo-image: url('${partner.logoMaskPath}'); --partner-logo-width: ${partner.logoWidth}; --partner-logo-max-height: ${partner.logoMaxHeight}; --partner-logo-width-mobile: ${partner.logoWidthMobile}; --partner-logo-max-height-mobile: ${partner.logoMaxHeightMobile}; --partner-panel-glow-a: ${partner.panelGlowA}; --partner-panel-glow-b: ${partner.panelGlowB}; --partner-panel-from: ${partner.panelFrom}; --partner-panel-mid: ${partner.panelMid}; --partner-panel-to: ${partner.panelTo}; --partner-panel-border: ${partner.panelBorder};`}
              >
                <div class="partner-hero-logo-shell">
                  <div
                    class="partner-hero-logo"
                    role="img"
                    aria-label={`Logo da operadora ${partner.name}`}
                  ></div>
                </div>
              </div>

              <aside class="partner-hero-meta" aria-label={`Informações da operadora ${partner.name}`}>
                <div class="partner-hero-meta-block">
                  <p class="partner-hero-meta-kicker">Leitura Klout</p>

                  <div class="partner-hero-meta-lines">
                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label partner-hero-meta-label-strong">Operadora:</span>
                      <span class="partner-hero-meta-value" data-value={partner.name}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>

                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label">Leitura:</span>
                      <span class="partner-hero-meta-value" data-value={partner.reading}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>

                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label">Foco:</span>
                      <span class="partner-hero-meta-value" data-value={partner.focus}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>
                  </div>
                </div>
              </aside>
            </div>

            <button
              type="button"
              class="partner-hero-slide-trigger control-button"
              aria-controls={partner.detailId}
              aria-expanded="false"
              aria-label={`Abrir aprofundamento da operadora ${partner.name}`}
            >
              <span
                class="partner-hero-slide-trigger-shape control-button__arrow control-button__arrow--right"
                aria-hidden="true"
              ></span>
            </button>
          </article>

          <article
            id={partner.detailId}
            class="partner-stage-panel partner-stage-panel-detail"
          >
            <div class="partner-detail-shell">
              <div class="partner-detail-body">
                <figure class="partner-detail-photo-frame">
                  <img
                    data-src="/images/partners/partner_01.webp"
                    alt={`Imagem editorial da seção da operadora ${partner.name}`}
                    class="partner-detail-photo"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>

                <div class="partner-detail-copy">
                  <p class="partner-detail-kicker">{`Base oficial ${partner.name}`}</p>
                  <h2 class="partner-detail-title">Cobertura com mais critério.</h2>
                  <p class="partner-detail-description">
                    {`A Klout analisa ${partner.name} sob a perspectiva de rede, modelo assistencial e elegibilidade para empresas, criando base para discussões mais claras sobre cobertura.`}
                  </p>
                </div>
              </div>

              <div class="partner-detail-footer">
                <button
                  type="button"
                  class="partner-detail-stage-back control-button"
                  aria-label="Voltar ao primeiro slide da seção"
                >
                  <span
                    class="partner-detail-stage-back-shape control-button__arrow control-button__arrow--left"
                    aria-hidden="true"
                  ></span>
                </button>

                {partner.nextId && (
                  <a href={`#${partner.nextId}`} class="partner-detail-skip">
                    Próxima operadora
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </article>
        </div>
      </section>
    ))}

    <section
      class="partners-page-closing"
      data-stack-section
      data-dark-section
      data-stack-end="150%"
      aria-labelledby="partners-page-closing-title"
    >
      <div class="partners-page-closing-shell">
        <p class="partners-page-closing-kicker">Curadoria Klout</p>
        <h2 id="partners-page-closing-title" class="partners-page-closing-title">
          Operadoras certas. Cobertura mais inteligente.
        </h2>
        <p class="partners-page-closing-description">
          Leitura consultiva para elevar rede, critério e previsibilidade nas condições do plano.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <FloatingNavbar />
</BaseLayout>

<script>
  const prefersReducedMotion =
    typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let gsapLoadPromise;
  let stackingLoadPromise;

  const getGsap = () => {
    if (!gsapLoadPromise) {
      gsapLoadPromise = import('gsap').then((module) => module.gsap);
    }

    return gsapLoadPromise;
  };

  const getStackingModules = () => {
    if (!stackingLoadPromise) {
      stackingLoadPromise = Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
      ]).then(([gsapModule, scrollTriggerModule]) => ({
        gsap: gsapModule.gsap,
        ScrollTrigger: scrollTriggerModule.ScrollTrigger,
      }));
    }

    return stackingLoadPromise;
  };

  const wait = (ms) =>
    new Promise((resolve) => {
      window.setTimeout(resolve, ms);
    });

  const animateTo = async (target, vars) => {
    const gsap = await getGsap();

    return new Promise((resolve) => {
      gsap.to(target, {
        ...vars,
        onComplete: resolve
      });
    });
  };

  const typeValue = async (valueEl, cursorEl, text) => {
    valueEl.textContent = '';
    cursorEl.classList.add('is-active');

    let index = 0;
    const chunkSize = 2;

    while (index < text.length) {
      index = Math.min(index + chunkSize, text.length);
      valueEl.textContent = text.slice(0, index);
      await wait(26);
    }

    await wait(120);
    cursorEl.classList.remove('is-active');
  };

  if (typeof window !== 'undefined') {
    window.addEventListener('load', () => {
      const hero = document.querySelector('.partners-page-hero');
      const heroNotes = Array.from(document.querySelectorAll('.partners-page-hero-note'));
      const arrivedViaPageTransition =
        document.documentElement.classList.contains('page-transition-enter');
      const heroRevealDelayMs =
        (window.__kloutPageTransition?.revealMs ?? 1020) + 80;

      const isTypingField = (target) =>
        target instanceof HTMLElement &&
        (target.isContentEditable ||
          ['INPUT', 'TEXTAREA', 'SELECT'].includes(target.tagName));

      const canUseStacking = () =>
        window.matchMedia('(min-width: 769px)').matches && !prefersReducedMotion;

      const scheduleStacking = () => {
        if (!canUseStacking()) return;

        let started = false;
        let fallbackTimer;
        let interactionTimer;
        let resizeTimer;
        const triggers = [];
        const pinnedSections = new Set();
        const interactionEvents = ['wheel', 'touchstart', 'pointerdown', 'scroll'];

        const hasFollowingSection = (section) => {
          const sections = Array.from(document.querySelectorAll('section'));
          const index = sections.indexOf(section);
          return index >= 0 && index < sections.length - 1;
        };

        const getPinEnd = (section) => {
          const customEnd = section.dataset.stackEnd;
          return customEnd ? `+=${customEnd}` : '+=220%';
        };

        const removeInteractionListeners = () => {
          interactionEvents.forEach((eventName) => {
            window.removeEventListener(eventName, handleInteraction, true);
          });
          window.removeEventListener('keydown', handleKeyInteraction, true);
        };

        const rebuildTriggers = (ScrollTrigger) => {
          triggers.forEach((trigger) => trigger.kill());
          triggers.length = 0;
          pinnedSections.clear();

          if (!canUseStacking()) return;

          document.querySelectorAll('[data-stack-section]:not(.slide-section)').forEach((section) => {
            if (!(section instanceof HTMLElement)) return;
            if (!hasFollowingSection(section) || pinnedSections.has(section)) return;

            pinnedSections.add(section);
            triggers.push(ScrollTrigger.create({
              trigger: section,
              start: 'top top',
              end: getPinEnd(section),
              scrub: true,
              pin: true,
              pinSpacing: false,
              anticipatePin: 0,
            }));
          });
        };

        const startStacking = async (delay = 0) => {
          if (started) return;
          started = true;
          removeInteractionListeners();
          window.clearTimeout(fallbackTimer);

          window.setTimeout(async () => {
            if (!canUseStacking()) return;

            const { gsap, ScrollTrigger } = await getStackingModules();
            gsap.registerPlugin(ScrollTrigger);
            rebuildTriggers(ScrollTrigger);

            window.addEventListener('resize', () => {
              window.clearTimeout(resizeTimer);
              resizeTimer = window.setTimeout(() => rebuildTriggers(ScrollTrigger), 200);
            }, { passive: true });
          }, delay);
        };

        function handleInteraction() {
          window.clearTimeout(interactionTimer);
          interactionTimer = window.setTimeout(() => void startStacking(), 120);
        }

        function handleKeyInteraction(event) {
          if (!['ArrowDown', 'ArrowUp', 'PageDown', 'PageUp', 'Home', 'End', ' '].includes(event.key)) return;
          handleInteraction();
        }

        interactionEvents.forEach((eventName) => {
          window.addEventListener(eventName, handleInteraction, {
            capture: true,
            passive: true,
          });
        });
        window.addEventListener('keydown', handleKeyInteraction, true);
        fallbackTimer = window.setTimeout(() => void startStacking(), 12000);
      };

      scheduleStacking();

      if (hero instanceof HTMLElement) {
        const revealHero = () => {
          hero.classList.add('is-ready');
        };

        const revealHeroAfterDelay = () => {
          window.setTimeout(() => {
            window.requestAnimationFrame(revealHero);
          }, heroRevealDelayMs);
        };

        if (prefersReducedMotion) {
          revealHero();
        } else if (arrivedViaPageTransition) {
          if (document.documentElement.classList.contains('page-transition-revealing')) {
            revealHeroAfterDelay();
          } else {
            const root = document.documentElement;
            const observer = new MutationObserver(() => {
              if (root.classList.contains('page-transition-revealing')) {
                observer.disconnect();
                revealHeroAfterDelay();
              }
            });

            observer.observe(root, { attributes: true, attributeFilter: ['class'] });

            window.setTimeout(() => {
              observer.disconnect();
              revealHeroAfterDelay();
            }, 1400);
          }
        } else {
          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(revealHero);
          });
        }
      }

      if (heroNotes.length) {
        heroNotes.forEach((note, index) => {
          note.classList.toggle('is-visible', index === 0);
        });

        if (!prefersReducedMotion && heroNotes.length > 1) {
          let activeNoteIndex = 0;
          window.setInterval(() => {
            const currentNote = heroNotes[activeNoteIndex];
            activeNoteIndex = (activeNoteIndex + 1) % heroNotes.length;
            const nextNote = heroNotes[activeNoteIndex];

            currentNote.classList.remove('is-visible');
            nextNote.classList.add('is-visible');
          }, 4160);
        }
      }

      const stageControllers = Array.from(document.querySelectorAll('.partner-stage-section')).map((stageSection) => {
        const heroSlideTrigger = stageSection.querySelector('.partner-hero-slide-trigger');
        const stageVeil = stageSection.querySelector('.partner-stage-veil');
        const stageTrack = stageSection.querySelector('.partner-stage-track');
        const heroShell = stageSection.querySelector('.partner-hero-shell');
        const heroPanel = stageSection.querySelector('.partner-hero-panel');
        const stageBackButton = stageSection.querySelector('.partner-detail-stage-back');
        const detailPhotoFrame = stageSection.querySelector('.partner-detail-photo-frame');
        const detailPhoto = stageSection.querySelector('.partner-detail-photo');
        const detailCopy = stageSection.querySelector('.partner-detail-copy');
        const detailFooter = stageSection.querySelector('.partner-detail-footer');
        const metaBlock = stageSection.querySelector('.partner-hero-meta-block');
        const rows = Array.from(stageSection.querySelectorAll('.partner-hero-meta-row'));
        const detailStageElements = [detailPhotoFrame, detailCopy, detailFooter].filter(Boolean);

        let isStageOpen = false;
        let isStageAnimating = false;
        let swipeStartX = 0;
        let swipeStartY = 0;
        let wheelDeltaX = 0;
        let wheelResetTimer = null;

        const setStagePosition = async (openStage) => {
          if (!(stageTrack instanceof HTMLElement)) return;
          if (isStageAnimating) return;

          isStageAnimating = true;
          isStageOpen = openStage;

          if (openStage && detailPhoto instanceof HTMLImageElement && !detailPhoto.currentSrc) {
            const deferredSrc = detailPhoto.dataset.src;
            if (deferredSrc) detailPhoto.src = deferredSrc;
          }

          if (heroSlideTrigger instanceof HTMLButtonElement) {
            heroSlideTrigger.disabled = openStage;
            heroSlideTrigger.setAttribute('aria-expanded', openStage ? 'true' : 'false');
          }

          if (prefersReducedMotion) {
            stageTrack.style.transform = openStage ? 'translate3d(-50%, 0, 0)' : 'translate3d(0, 0, 0)';
            if (detailPhotoFrame instanceof HTMLElement) {
              detailPhotoFrame.style.clipPath = openStage ? 'inset(0 0% 0 0)' : 'inset(0 14% 0 0)';
              detailPhotoFrame.style.opacity = openStage ? '1' : '0';
              detailPhotoFrame.style.transform = openStage ? 'scale(1)' : 'scale(1.03)';
              detailPhotoFrame.style.filter = openStage ? 'blur(0px)' : 'blur(6px)';
            }
            if (detailPhoto instanceof HTMLElement) {
              detailPhoto.style.transform = openStage
                ? 'translate3d(0, 0, 0) scale(1) rotate(0.001deg)'
                : 'translate3d(0, 4%, 0) scale(1.14) rotate(0.001deg)';
            }
            detailStageElements.forEach((element) => {
              if (!(element instanceof HTMLElement)) return;
              if (element === detailPhotoFrame) return;
              element.style.opacity = openStage ? '1' : '0';
              element.style.transform = openStage ? 'translate3d(0, 0, 0)' : 'translate3d(20px, 12px, 0)';
              element.style.filter = openStage ? 'blur(0px)' : 'blur(4px)';
            });
            isStageAnimating = false;
            return;
          }

          const gsap = await getGsap();

          const timeline = gsap.timeline({
            defaults: {
              duration: 0.84,
              ease: 'power2.inOut'
            },
            onComplete: () => {
              isStageAnimating = false;
            }
          });

          if (openStage) {
            timeline
              .set(stageVeil, {
                autoAlpha: 0,
                scaleX: 0,
                transformOrigin: '100% 50%'
              }, 0)
              .to(stageVeil, {
                autoAlpha: 0.7,
                scaleX: 1,
                duration: 0.42,
                ease: 'power2.inOut'
              }, 0)
              .to(stageTrack, { xPercent: -50 }, 0.1)
              .to(heroShell, {
                x: -18,
                scale: 0.992,
                autoAlpha: 0.76,
                filter: 'blur(4px)'
              }, 0.02)
              .to(heroPanel, {
                yPercent: -1.1,
                scale: 0.992,
                filter: 'blur(1px)'
              }, 0.02)
              .fromTo(detailPhotoFrame, {
                clipPath: 'inset(0 14% 0 0)',
                scale: 1.03,
                autoAlpha: 0,
                filter: 'blur(6px)'
              }, {
                clipPath: 'inset(0 0% 0 0)',
                scale: 1,
                autoAlpha: 1,
                filter: 'blur(0px)',
                duration: 0.72,
                ease: 'power2.out'
              }, 0.16)
              .fromTo(detailPhoto, {
                scale: 1.14,
                yPercent: 4,
                rotate: 0.001
              }, {
                scale: 1,
                yPercent: 0,
                rotate: 0.001,
                duration: 1.02,
                ease: 'expo.out'
              }, 0.2)
              .fromTo([detailCopy, detailFooter], {
                x: 20,
                y: 12,
                autoAlpha: 0,
                filter: 'blur(4px)',
              }, {
                x: 0,
                y: 0,
                autoAlpha: 1,
                filter: 'blur(0px)',
                duration: 0.52,
                stagger: 0.05,
                ease: 'power2.out'
              }, 0.26)
              .to(stageVeil, {
                scaleX: 0,
                transformOrigin: '0% 50%',
                autoAlpha: 0,
                duration: 0.46,
                ease: 'power2.inOut'
              }, 0.28);

            return;
          }

          timeline
            .set(stageVeil, {
              autoAlpha: 0,
              scaleX: 0,
              transformOrigin: '0% 50%'
            }, 0)
            .to(stageVeil, {
              autoAlpha: 0.68,
              scaleX: 1,
              duration: 0.4,
              ease: 'power2.inOut'
            }, 0)
            .to([detailCopy, detailFooter], {
              x: 0,
              y: 10,
              autoAlpha: 0,
              filter: 'blur(4px)',
              duration: 0.28,
              stagger: 0.04,
              ease: 'power2.in'
            }, 0)
            .to(detailPhotoFrame, {
              clipPath: 'inset(0 14% 0 0)',
              scale: 1.03,
              autoAlpha: 0.5,
              filter: 'blur(6px)',
              duration: 0.34,
              ease: 'power2.in'
            }, 0.02)
            .to(detailPhoto, {
              scale: 1.08,
              yPercent: -2,
              rotate: 0.001,
              duration: 0.34,
              ease: 'power2.in'
            }, 0.02)
            .to(stageTrack, { xPercent: 0 }, 0.08)
            .to(heroShell, {
              x: 0,
              scale: 1,
              autoAlpha: 1,
              filter: 'blur(0px)'
            }, 0.18)
            .to(heroPanel, {
              yPercent: 0,
              scale: 1,
              filter: 'blur(0px)'
            }, 0.18)
            .to(stageVeil, {
              scaleX: 0,
              transformOrigin: '100% 50%',
              autoAlpha: 0,
              duration: 0.42,
              ease: 'power2.inOut'
            }, 0.22);
        };

        heroSlideTrigger?.addEventListener('click', () => {
          if (isStageOpen) return;
          void setStagePosition(true);
        });

        stageBackButton?.addEventListener('click', () => {
          if (!isStageOpen) return;
          void setStagePosition(false);
        });

        stageSection.addEventListener('touchstart', (event) => {
          const touch = event.touches[0];
          if (!touch) return;
          swipeStartX = touch.clientX;
          swipeStartY = touch.clientY;
        }, { passive: true });

        stageSection.addEventListener('touchend', (event) => {
          const touch = event.changedTouches[0];
          if (!touch) return;

          const deltaX = touch.clientX - swipeStartX;
          const deltaY = touch.clientY - swipeStartY;

          if (Math.abs(deltaX) < 56 || Math.abs(deltaX) < Math.abs(deltaY)) return;

          if (deltaX < 0 && !isStageOpen) {
            void setStagePosition(true);
          }

          if (deltaX > 0 && isStageOpen) {
            void setStagePosition(false);
          }
        }, { passive: true });

        stageSection.addEventListener('wheel', (event) => {
          const dominantHorizontalDelta =
            Math.abs(event.deltaX) >= Math.abs(event.deltaY)
              ? event.deltaX
              : event.shiftKey
                ? event.deltaY
                : 0;

          if (Math.abs(dominantHorizontalDelta) < 4) return;

          event.preventDefault();

          wheelDeltaX += dominantHorizontalDelta;

          if (wheelResetTimer) {
            window.clearTimeout(wheelResetTimer);
          }

          wheelResetTimer = window.setTimeout(() => {
            wheelDeltaX = 0;
          }, 140);

          if (isStageAnimating || Math.abs(wheelDeltaX) < 72) return;

          if (wheelDeltaX > 0 && !isStageOpen) {
            wheelDeltaX = 0;
            void setStagePosition(true);
            return;
          }

          if (wheelDeltaX < 0 && isStageOpen) {
            wheelDeltaX = 0;
            void setStagePosition(false);
          }
        }, { passive: false });

        if (metaBlock && rows.length) {
          if (prefersReducedMotion) {
            rows.forEach((row) => {
              const valueEl = row.querySelector('.partner-hero-meta-value');
              const text = valueEl?.getAttribute('data-value') ?? '';
              if (valueEl) valueEl.textContent = text;
            });
          } else {
            const metaObserver = new IntersectionObserver(async (entries, observer) => {
              if (!entries.some((entry) => entry.isIntersecting)) return;

              observer.disconnect();

              const gsap = await getGsap();

              gsap.set(metaBlock, { autoAlpha: 1 });
              gsap.set(rows, { autoAlpha: 0, y: 12 });

              await animateTo(metaBlock, {
                autoAlpha: 1,
                duration: 0.4,
                ease: 'sine.out'
              });

              for (const row of rows) {
                const valueEl = row.querySelector('.partner-hero-meta-value');
                const cursorEl = row.querySelector('.partner-hero-meta-cursor');
                const text = valueEl?.getAttribute('data-value') ?? '';

                if (!valueEl || !cursorEl) continue;

                await animateTo(row, {
                  autoAlpha: 1,
                  y: 0,
                  duration: 0.42,
                  ease: 'sine.out'
                });

                await typeValue(valueEl, cursorEl, text);
                await wait(90);
              }
            }, { threshold: 0.55 });

            metaObserver.observe(stageSection);
          }
        }

        return {
          stageSection,
          isStageOpen: () => isStageOpen,
          setStagePosition
        };
      });

      const getActiveStageController = () => {
        const viewportMidpoint = window.innerHeight * 0.5;

        return stageControllers.find(({ stageSection }) => {
          const rect = stageSection.getBoundingClientRect();
          return rect.top <= viewportMidpoint && rect.bottom >= viewportMidpoint;
        });
      };

      window.addEventListener('keydown', (event) => {
        if (isTypingField(event.target)) return;

        const activeStageController = getActiveStageController();
        if (!activeStageController) return;

        if (event.key === 'ArrowRight' && !activeStageController.isStageOpen()) {
          event.preventDefault();
          void activeStageController.setStagePosition(true);
        }

        if (event.key === 'ArrowLeft' && activeStageController.isStageOpen()) {
          event.preventDefault();
          void activeStageController.setStagePosition(false);
        }
      });
    }, { once: true });
  }
</script>

