---
import BaseLayout from '../layouts/Base.astro';
import FloatingNavbar from '../components/navbar/FloatingNavbar.svelte';
import Footer from '../components/Footer.svelte';
import { kloutPartnersSchema } from '../lib/schema';

const partners = [
  {
    slug: 'alice',
    name: 'Alice',
    logoMaskPath: '/images/logos_svgs/logo_alice_cropped.svg',
    logoWidth: 'min(100%, 16rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 10rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    logoMobileX: '-1.5rem',
    logoMobileY: '-2rem',
    logoWidthMobileWide: 'min(100%, 10rem)',
    logoMaxHeightMobileWide: 'min(68%, 13rem)',
    logoMobileWideX: '0rem',
    logoMobileWideY: '-2rem',
    panelGlowA: 'hsla(206, 52%, 58%, 0.22)',
    panelGlowB: 'hsla(220, 58%, 11%, 0.28)',
    panelFrom: 'hsl(210, 34%, 34%)',
    panelMid: 'hsl(214, 38%, 25%)',
    panelTo: 'hsl(218, 44%, 18%)',
    panelBorder: 'hsla(210, 24%, 92%, 0.07)',
    reading: 'atenção coordenada, tecnologia e acompanhamento contínuo',
    focus: 'empresas que valorizam cuidado próximo e uso simples do plano',
    detailTitle: 'Rigor clínico e inovação em saúde empresarial',
    detailDescription:
      'Para empresas que procuram mais do que uma rede qualificada para a equipe, a Alice oferece tecnologias que facilitam o uso do plano e assistência personalizada, feita por especialistas que acompanham individualmente o usuário com base em histórico e contexto.',
    detailPhotoWebp: '/images/partners/partner_01.webp',
  },
  {
    slug: 'porto',
    name: 'Porto',
    logoMaskPath: '/images/logos_svgs/logo_porto.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 24rem)',
    logoMaxHeightMobile: 'min(70%, 14rem)',
    logoMobileX: '-1.5rem',
    logoMobileY: '-2rem',
    logoWidthMobileWide: 'min(100%, 24rem)',
    logoMaxHeightMobileWide: 'min(70%, 14rem)',
    logoMobileWideX: '0rem',
    logoMobileWideY: '-2rem',
    panelGlowA: 'hsla(208, 34%, 48%, 0.12)',
    panelGlowB: 'hsla(220, 62%, 8%, 0.34)',
    panelFrom: 'hsl(212, 28%, 24%)',
    panelMid: 'hsl(215, 34%, 18%)',
    panelTo: 'hsl(220, 40%, 12%)',
    panelBorder: 'hsla(210, 18%, 88%, 0.05)',
    reading: 'rede referenciada, canais digitais e marca de alta confiança',
    focus: 'pessoas, famílias e empresas que buscam praticidade no uso',
    detailTitle: 'Experiência digital e cobertura com previsibilidade operacional',
    detailDescription:
      'Quando a prioridade é simplificar a rotina de uso do plano, a Porto combina rede referenciada, app para consulta de rede, teleconsulta e solicitação de reembolso em uma experiência direta para pessoas, famílias e empresas. Em contratos empresariais, essa estrutura também ajuda o RH a operar o benefício com mais clareza.',
    detailPhotoAvif: '/images/partners/partner_02.avif',
    detailPhotoWebp: '/images/partners/partner_02.webp',
  },
  {
    slug: 'bradesco',
    name: 'Bradesco',
    logoMaskPath: '/images/logos_svgs/logo_bradesco.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 21rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    logoMobileX: '-1.5rem',
    logoMobileY: '-2rem',
    logoWidthMobileWide: 'min(100%, 21rem)',
    logoMaxHeightMobileWide: 'min(68%, 13rem)',
    logoMobileWideX: '0rem',
    logoMobileWideY: '-2rem',
    panelGlowA: 'hsla(206, 38%, 56%, 0.16)',
    panelGlowB: 'hsla(220, 52%, 10%, 0.28)',
    panelFrom: 'hsl(210, 30%, 30%)',
    panelMid: 'hsl(214, 34%, 22%)',
    panelTo: 'hsl(219, 38%, 16%)',
    panelBorder: 'hsla(210, 24%, 92%, 0.06)',
    reading: 'capilaridade nacional, reembolso e desenho por categoria',
    focus: 'usuários que precisam de acesso robusto em diferentes regiões',
    detailTitle: 'Rede nacional robusta para estruturas corporativas complexas',
    detailDescription:
      'Para quem valoriza capilaridade e acesso em diferentes regiões, a Bradesco Saúde oferece rede nacional, serviços digitais e opções de reembolso conforme a linha contratada. Em empresas com equipes distribuídas ou níveis distintos de elegibilidade, a curadoria ajuda a alinhar rede, categoria de plano e experiência real de uso.',
    detailPhotoAvif: '/images/partners/partner_03.avif',
    detailPhotoWebp: '/images/partners/partner_03.webp',
  },
  {
    slug: 'sulamerica',
    name: 'SulAmerica',
    logoMaskPath: '/images/logos_svgs/logo_sulamerica.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 22rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    logoMobileX: '-1.5rem',
    logoMobileY: '-2rem',
    logoWidthMobileWide: 'min(100%, 22rem)',
    logoMaxHeightMobileWide: 'min(68%, 13rem)',
    logoMobileWideX: '0rem',
    logoMobileWideY: '-2rem',
    panelGlowA: 'hsla(198, 44%, 58%, 0.18)',
    panelGlowB: 'hsla(221, 56%, 11%, 0.26)',
    panelFrom: 'hsl(206, 34%, 34%)',
    panelMid: 'hsl(211, 37%, 25%)',
    panelTo: 'hsl(217, 43%, 18%)',
    panelBorder: 'hsla(208, 24%, 92%, 0.07)',
    reading: 'rede ampla, autonomia digital e boa percepção de atendimento',
    focus: 'perfis que equilibram escolha, conveniência e previsibilidade',
    detailTitle: 'Flexibilidade de rede com jornada digital de cuidado',
    detailDescription:
      'A SulAmérica atende bem quem busca equilibrar abrangência, escolha e conveniência no uso diário. A operadora reúne rede referenciada ampla, busca por geolocalização, Saúde na Tela e bons indicadores recentes de satisfação, criando uma base sólida para pessoas, famílias e equipes que valorizam acesso, autonomia e previsibilidade.',
    detailPhotoAvif: '/images/partners/partner_04.avif',
    detailPhotoWebp: '/images/partners/partner_04.webp',
    detailPhotoPosition: 'center bottom',
  },
  {
    slug: 'omint',
    name: 'Omint',
    logoMaskPath: '/images/logos_svgs/logo_omint.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 19rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    logoMobileX: '-1.5rem',
    logoMobileY: '-2rem',
    logoWidthMobileWide: 'min(100%, 19rem)',
    logoMaxHeightMobileWide: 'min(68%, 13rem)',
    logoMobileWideX: '0rem',
    logoMobileWideY: '-2rem',
    panelGlowA: 'hsla(212, 32%, 50%, 0.12)',
    panelGlowB: 'hsla(222, 62%, 7%, 0.34)',
    panelFrom: 'hsl(216, 28%, 22%)',
    panelMid: 'hsl(220, 32%, 16%)',
    panelTo: 'hsl(224, 38%, 10%)',
    panelBorder: 'hsla(42, 18%, 82%, 0.06)',
    reading: 'experiência premium, rede qualificada e gestão próxima',
    focus: 'quem prioriza alto padrão assistencial e suporte consultivo',
    detailTitle: 'Padrão premium com suporte estratégico para o RH',
    detailDescription:
      'A Omint conversa com quem procura uma experiência de saúde premium, com rede de alto padrão, coberturas diferenciadas e atenção próxima aos detalhes do cuidado. Para empresas, adiciona gestor dedicado, relatórios gerenciais e programas de qualidade de vida, elevando a gestão do benefício sem perder o foco na experiência do usuário.',
    detailPhotoAvif: '/images/partners/partner_05.avif',
    detailPhotoWebp: '/images/partners/partner_05.webp',
  },
  {
    slug: 'amil',
    name: 'Amil',
    logoMaskPath: '/images/logos_svgs/logo_amil.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 20rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    logoMobileX: '-1.5rem',
    logoMobileY: '-2rem',
    logoWidthMobileWide: 'min(100%, 20rem)',
    logoMaxHeightMobileWide: 'min(68%, 13rem)',
    logoMobileWideX: '0rem',
    logoMobileWideY: '-2rem',
    panelGlowA: 'hsla(204, 40%, 60%, 0.16)',
    panelGlowB: 'hsla(220, 58%, 9%, 0.3)',
    panelFrom: 'hsl(208, 33%, 31%)',
    panelMid: 'hsl(213, 37%, 22%)',
    panelTo: 'hsl(218, 41%, 15%)',
    panelBorder: 'hsla(210, 26%, 92%, 0.06)',
    reading: 'rede nacional, unidades próprias e telemedicina disponível',
    focus: 'pessoas e equipes que precisam de escala e acesso recorrente',
    detailTitle: 'Escala assistencial com rede própria e acesso digital',
    detailDescription:
      'A Amil combina capilaridade, rede credenciada nacional, unidades próprias, telemedicina 24/7 e serviços pelo app para organizar o acesso ao cuidado sem depender apenas do atendimento presencial. Para empresas, essa escala pode favorecer equipes maiores ou distribuídas, com mais opções de contratação e uso assistencial.',
    detailPhotoAvif: '/images/partners/partner_06.avif',
    detailPhotoWebp: '/images/partners/partner_06.webp',
  },
];

const partnerSections = partners.map((partner, index) => {
  const id = `parceiro-${partner.slug}`;
  const nextPartner = partners[index + 1];

  return {
    ...partner,
    id,
    detailId: `${id}-detalhes`,
    nextId: nextPartner ? `parceiro-${nextPartner.slug}` : null,
  };
});
---

<BaseLayout
  title="Parceiros | Klout"
  description="Conheça a rede de parceiros da Klout e como a curadoria especializada conecta seguradoras, empresas e clientes com mais eficiência."
  smoothScrollDelay={900}
  structuredData={kloutPartnersSchema}
>
  <main id="main-content">
    <section
      id="parceiros"
      class="partners-page-hero"
      data-stack-section
      data-stack-end="185%"
    >
      <div class="partners-page-geo" aria-hidden="true">
        <div class="partners-page-geo-line partners-page-geo-line-v1"></div>
        <div class="partners-page-geo-line partners-page-geo-line-v2"></div>
        <div class="partners-page-geo-line partners-page-geo-line-v3"></div>
        <div class="partners-page-geo-line partners-page-geo-line-h1"></div>
        <div class="partners-page-geo-line partners-page-geo-line-h2"></div>
      </div>
      <div class="partners-page-hero-shell">
        <div class="partners-page-hero-copy">
          <h1 class="partners-page-hero-title">Rede de parcerias Klout</h1>
        </div>

        <div class="partners-page-hero-visual" aria-label="Mapa do Brasil com operadoras parceiras">
          <div class="partners-page-hero-map" aria-hidden="true"></div>

          <div class="partners-page-hero-node partners-page-hero-node-alice">
            <img src="/images/logos_svgs/logo_alice.svg" alt="Alice" class="partners-page-hero-node-logo partners-page-hero-node-logo-alice" loading="lazy" width="210" height="297" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-porto">
            <img src="/images/logos_svgs/logo_porto.svg" alt="Porto" class="partners-page-hero-node-logo partners-page-hero-node-logo-porto" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-bradesco">
            <img src="/images/logos_svgs/logo_bradesco.svg" alt="Bradesco" class="partners-page-hero-node-logo partners-page-hero-node-logo-bradesco" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-sulamerica">
            <img src="/images/logos_svgs/logo_sulamerica.svg" alt="SulAmerica" class="partners-page-hero-node-logo partners-page-hero-node-logo-sulamerica" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-omint">
            <img src="/images/logos_svgs/logo_omint.svg" alt="Omint" class="partners-page-hero-node-logo partners-page-hero-node-logo-omint" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-amil">
            <img src="/images/logos_svgs/logo_amil.svg" alt="Amil" class="partners-page-hero-node-logo partners-page-hero-node-logo-amil" loading="lazy" width="4096" height="4096" />
          </div>
        </div>

        <div class="partners-page-hero-rail">
          <div class="partners-page-hero-notes" aria-label="Diferenciais da rede de parcerias Klout">
            <p class="partners-page-hero-note">
              Operadoras rigorosamente selecionadas pela curadoria Klout
            </p>
            <p class="partners-page-hero-note">
              Acesso mais amplo a serviços médicos e melhores hospitais
            </p>
            <p class="partners-page-hero-note">
                Comparação feita para melhorar acesso sem inflar custo com benefícios que não serão usados
            </p>
          </div>

          <a
            href="#parceiro-alice"
            class="partners-page-hero-cta control-button"
            aria-label="Ir para a primeira operadora"
          >
            <span class="control-button__arrow control-button__arrow--right" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    </section>

    {partnerSections.map((partner) => (
      <section
        id={partner.id}
        class="partner-stage-section"
        data-stack-section
        data-stack-end="220%"
      >
        <div class="partner-stage-veil" aria-hidden="true"></div>
        <div class="partner-stage-track">
          <article
            class={`partner-stage-panel partner-stage-panel-hero ${partner.slug === 'alice' ? 'partner-stage-panel-hero-alice' : ''}`}
            style={`--partner-panel-glow-a: ${partner.panelGlowA}; --partner-panel-glow-b: ${partner.panelGlowB}; --partner-panel-from: ${partner.panelFrom}; --partner-panel-mid: ${partner.panelMid}; --partner-panel-to: ${partner.panelTo};`}
          >
            <div class="partner-hero-shell">
              <div
                class={`partner-hero-logo-shell partner-hero-logo-shell-standalone ${partner.slug === 'alice' ? 'partner-hero-logo-shell-alice' : ''}`}
                style={`--partner-logo-width: ${partner.logoWidth}; --partner-logo-max-height: ${partner.logoMaxHeight}; --partner-logo-width-mobile: ${partner.logoWidthMobile}; --partner-logo-max-height-mobile: ${partner.logoMaxHeightMobile}; --partner-logo-mobile-x: ${partner.logoMobileX}; --partner-logo-mobile-y: ${partner.logoMobileY}; --partner-logo-width-mobile-wide: ${partner.logoWidthMobileWide}; --partner-logo-max-height-mobile-wide: ${partner.logoMaxHeightMobileWide}; --partner-logo-mobile-wide-x: ${partner.logoMobileWideX}; --partner-logo-mobile-wide-y: ${partner.logoMobileWideY};`}
              >
                <img
                  src={partner.logoMaskPath}
                  alt={`Logo da operadora ${partner.name}`}
                  class="partner-hero-logo"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <aside class="partner-hero-meta" aria-label={`Informações da operadora ${partner.name}`}>
                <div class="partner-hero-meta-block">
                  <p class="partner-hero-meta-kicker">Leitura Klout</p>

                  <div class="partner-hero-meta-lines">
                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label partner-hero-meta-label-strong">Operadora:</span>
                      <span class="partner-hero-meta-value" data-value={partner.name}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>

                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label">Leitura:</span>
                      <span class="partner-hero-meta-value" data-value={partner.reading}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>

                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label">Foco:</span>
                      <span class="partner-hero-meta-value" data-value={partner.focus}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>
                  </div>
                </div>
              </aside>
            </div>

            <button
              type="button"
              class="partner-hero-slide-trigger control-button"
              aria-controls={partner.detailId}
              aria-expanded="false"
              aria-label={`Abrir aprofundamento da operadora ${partner.name}`}
            >
              <span
                class="partner-hero-slide-trigger-shape control-button__arrow control-button__arrow--right"
                aria-hidden="true"
              ></span>
            </button>
          </article>

          <article
            id={partner.detailId}
            class="partner-stage-panel partner-stage-panel-detail"
          >
            <div class="partner-detail-shell">
              <div class="partner-detail-body">
                <figure
                  class="partner-detail-photo-frame"
                  style={`--partner-detail-photo-position: ${partner.detailPhotoPosition ?? 'center'}`}
                >
                  <picture class="partner-detail-picture">
                    {partner.detailPhotoAvif && (
                      <source data-srcset={partner.detailPhotoAvif} type="image/avif" />
                    )}
                    <source data-srcset={partner.detailPhotoWebp} type="image/webp" />
                    <img
                      data-src={partner.detailPhotoWebp}
                      alt={`Imagem editorial da seção da operadora ${partner.name}`}
                      class="partner-detail-photo"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                </figure>

                <div class="partner-detail-copy">
                  <p class="partner-detail-kicker">{`Base oficial ${partner.name}`}</p>
                  <h2 class="partner-detail-title">{partner.detailTitle ?? 'Cobertura com mais critério.'}</h2>
                  <p class="partner-detail-description">
                    {partner.detailDescription ??
                      `A Klout analisa ${partner.name} sob a perspectiva de rede, modelo assistencial e elegibilidade para empresas, criando base para discussões mais claras sobre cobertura.`}
                  </p>
                  <a href="/analise" class="partner-detail-consultant-link">
                    Conversar com consultor
                  </a>
                </div>
              </div>

              <div class="partner-detail-footer">
                <button
                  type="button"
                  class="partner-detail-stage-back control-button"
                  aria-label="Voltar ao primeiro slide da seção"
                >
                  <span
                    class="partner-detail-stage-back-shape control-button__arrow control-button__arrow--left"
                    aria-hidden="true"
                  ></span>
                </button>

                {partner.nextId && (
                  <a href={`#${partner.nextId}`} class="partner-detail-skip">
                    Próxima operadora
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </article>
        </div>
      </section>
    ))}

    <section
      class="partners-page-closing"
      data-stack-section
      data-dark-section
      data-stack-end="150%"
      aria-labelledby="partners-page-closing-title"
    >
      <div class="partners-page-closing-shell">
        <p class="partners-page-closing-kicker">Curadoria Klout</p>
        <h2 id="partners-page-closing-title" class="partners-page-closing-title">
          Operadoras certas. Cobertura mais inteligente.
        </h2>
        <p class="partners-page-closing-description">
          Leitura consultiva para elevar rede, critério e previsibilidade nas condições do plano.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <FloatingNavbar />
</BaseLayout>

<script is:inline>
  const loadPartnersScript = () => {
    window.requestAnimationFrame(() => {
      const script = document.createElement('script');
      script.type = 'module';
      script.fetchPriority = 'low';
      script.async = true;
      script.src = '/scripts/partners-page.js';
      document.head.appendChild(script);
    });
  };

  if (document.readyState === 'loading') {
    window.addEventListener('DOMContentLoaded', loadPartnersScript, { once: true });
  } else {
    loadPartnersScript();
  }
</script>

<style>
  .partner-stack-section {
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      hsl(214, 42%, 10%) 0%,
      hsl(214, 32%, 7%) 100%
    );
  }

  .partners-page-hero {
    --partners-hero-line-duration: 980ms;
    --partners-hero-main-duration: 1180ms;
    --partners-hero-node-duration: 1120ms;
    --partners-hero-rail-duration: 920ms;
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, hsla(42, 42%, 72%, 0.16) 0%, transparent 36%),
      radial-gradient(circle at 78% 22%, hsla(206, 52%, 68%, 0.16) 0%, transparent 28%),
      linear-gradient(
        180deg,
        hsl(42, 30%, 97.8%) 0%,
        hsl(206, 34%, 96.2%) 56%,
        hsl(210, 28%, 93.8%) 100%
      );
  }

  .partners-page-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .partners-page-geo-line {
    position: absolute;
    opacity: 0.34;
    transform: scaleX(1);
    transform-origin: 50% 50%;
    transition:
      opacity var(--partners-hero-line-duration) cubic-bezier(0.22, 1, 0.36, 1),
      transform var(--partners-hero-line-duration) cubic-bezier(0.22, 1, 0.36, 1);
  }

  .partners-page-geo-line-v1,
  .partners-page-geo-line-v2,
  .partners-page-geo-line-v3 {
    width: 1px;
    background: linear-gradient(
      180deg,
      hsla(214, 15%, 60%, 0) 0%,
      hsla(214, 15%, 60%, 0.2) 50%,
      hsla(214, 15%, 60%, 0) 100%
    );
  }

  .partners-page-geo-line-v1 {
    height: 56%;
    top: 18%;
    left: 11%;
  }

  .partners-page-geo-line-v2 {
    height: 64%;
    top: 12%;
    right: 18%;
  }

  .partners-page-geo-line-v3 {
    height: 42%;
    top: 34%;
    left: 58%;
  }

  .partners-page-geo-line-h1,
  .partners-page-geo-line-h2 {
    height: 1px;
    background: linear-gradient(
      90deg,
      hsla(214, 15%, 60%, 0) 0%,
      hsla(214, 15%, 60%, 0.16) 50%,
      hsla(214, 15%, 60%, 0) 100%
    );
  }

  .partners-page-geo-line-h1 {
    width: 42%;
    top: 33%;
    left: 0;
  }

  .partners-page-geo-line-h2 {
    width: 34%;
    bottom: 24%;
    right: 0;
  }

  .partners-page-hero-shell {
    width: 100%;
    min-height: 100vh;
    box-sizing: border-box;
    max-width: 1320px;
