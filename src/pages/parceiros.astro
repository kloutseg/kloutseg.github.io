---
import BaseLayout from '../layouts/Base.astro';
import FloatingNavbar from '../components/navbar/FloatingNavbar.svelte';
import Footer from '../components/Footer.svelte';

const partners = [
  {
    slug: 'alice',
    name: 'Alice',
    logoMaskPath: '/images/logos_svgs/logo_alice_cropped.svg',
    logoWidth: 'min(100%, 16rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 18rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(206, 52%, 58%, 0.22)',
    panelGlowB: 'hsla(220, 58%, 11%, 0.28)',
    panelFrom: 'hsl(210, 34%, 34%)',
    panelMid: 'hsl(214, 38%, 25%)',
    panelTo: 'hsl(218, 44%, 18%)',
    panelBorder: 'hsla(210, 24%, 92%, 0.07)',
    reading: 'coordenação e jornada',
    focus: 'modelo assistencial',
  },
  {
    slug: 'porto',
    name: 'Porto',
    logoMaskPath: '/images/logos_svgs/logo_porto.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 24rem)',
    logoMaxHeightMobile: 'min(70%, 14rem)',
    panelGlowA: 'hsla(208, 34%, 48%, 0.12)',
    panelGlowB: 'hsla(220, 62%, 8%, 0.34)',
    panelFrom: 'hsl(212, 28%, 24%)',
    panelMid: 'hsl(215, 34%, 18%)',
    panelTo: 'hsl(220, 40%, 12%)',
    panelBorder: 'hsla(210, 18%, 88%, 0.05)',
    reading: 'rede ampla e estabilidade',
    focus: 'cobertura corporativa previsível',
  },
  {
    slug: 'bradesco',
    name: 'Bradesco',
    logoMaskPath: '/images/logos_svgs/logo_bradesco.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 21rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(206, 38%, 56%, 0.16)',
    panelGlowB: 'hsla(220, 52%, 10%, 0.28)',
    panelFrom: 'hsl(210, 30%, 30%)',
    panelMid: 'hsl(214, 34%, 22%)',
    panelTo: 'hsl(219, 38%, 16%)',
    panelBorder: 'hsla(210, 24%, 92%, 0.06)',
    reading: 'rede e previsibilidade',
    focus: 'capilaridade assistencial',
  },
  {
    slug: 'sulamerica',
    name: 'SulAmerica',
    logoMaskPath: '/images/logos_svgs/logo_sulamerica.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 22rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(198, 44%, 58%, 0.18)',
    panelGlowB: 'hsla(221, 56%, 11%, 0.26)',
    panelFrom: 'hsl(206, 34%, 34%)',
    panelMid: 'hsl(211, 37%, 25%)',
    panelTo: 'hsl(217, 43%, 18%)',
    panelBorder: 'hsla(208, 24%, 92%, 0.07)',
    reading: 'flexibilidade e desenho',
    focus: 'elegibilidade corporativa',
  },
  {
    slug: 'omint',
    name: 'Omint',
    logoMaskPath: '/images/logos_svgs/logo_omint.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 19rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(212, 32%, 50%, 0.12)',
    panelGlowB: 'hsla(222, 62%, 7%, 0.34)',
    panelFrom: 'hsl(216, 28%, 22%)',
    panelMid: 'hsl(220, 32%, 16%)',
    panelTo: 'hsl(224, 38%, 10%)',
    panelBorder: 'hsla(42, 18%, 82%, 0.06)',
    reading: 'padrão premium e rede',
    focus: 'cobertura executiva',
  },
  {
    slug: 'amil',
    name: 'Amil',
    logoMaskPath: '/images/logos_svgs/logo_amil.svg',
    logoWidth: 'min(100%, 42rem)',
    logoMaxHeight: 'min(100%, 36rem)',
    logoWidthMobile: 'min(100%, 20rem)',
    logoMaxHeightMobile: 'min(68%, 13rem)',
    panelGlowA: 'hsla(204, 40%, 60%, 0.16)',
    panelGlowB: 'hsla(220, 58%, 9%, 0.3)',
    panelFrom: 'hsl(208, 33%, 31%)',
    panelMid: 'hsl(213, 37%, 22%)',
    panelTo: 'hsl(218, 41%, 15%)',
    panelBorder: 'hsla(210, 26%, 92%, 0.06)',
    reading: 'capilaridade e acesso',
    focus: 'escala de cobertura',
  },
];

const partnerSections = partners.map((partner, index) => {
  const id = `parceiro-${partner.slug}`;
  const nextPartner = partners[index + 1];

  return {
    ...partner,
    id,
    detailId: `${id}-detalhes`,
    nextId: nextPartner ? `parceiro-${nextPartner.slug}` : null,
  };
});
---

<BaseLayout
  title="Parceiros | Klout"
  description="Conheça a rede de parceiros da Klout e como a curadoria especializada conecta seguradoras, empresas e clientes com mais eficiência."
  preloadFonts={false}
  loadCustomFonts={false}
  smoothScrollDelay={900}
>
  <main id="main-content">
    <section
      id="parceiros"
      class="partners-page-hero"
      data-stack-section
      data-stack-end="185%"
    >
      <div class="partners-page-geo" aria-hidden="true">
        <div class="partners-page-geo-line partners-page-geo-line-v1"></div>
        <div class="partners-page-geo-line partners-page-geo-line-v2"></div>
        <div class="partners-page-geo-line partners-page-geo-line-v3"></div>
        <div class="partners-page-geo-line partners-page-geo-line-h1"></div>
        <div class="partners-page-geo-line partners-page-geo-line-h2"></div>
      </div>
      <div class="partners-page-hero-shell">
        <div class="partners-page-hero-copy">
          <h1 class="partners-page-hero-title">Rede de parcerias Klout</h1>
        </div>

        <div class="partners-page-hero-visual" aria-label="Mapa do Brasil com operadoras parceiras">
          <div class="partners-page-hero-map" aria-hidden="true"></div>

          <div class="partners-page-hero-node partners-page-hero-node-alice">
            <img src="/images/logos_svgs/logo_alice.svg" alt="Alice" class="partners-page-hero-node-logo partners-page-hero-node-logo-alice" loading="lazy" width="210" height="297" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-porto">
            <img src="/images/logos_svgs/logo_porto.svg" alt="Porto" class="partners-page-hero-node-logo partners-page-hero-node-logo-porto" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-bradesco">
            <img src="/images/logos_svgs/logo_bradesco.svg" alt="Bradesco" class="partners-page-hero-node-logo partners-page-hero-node-logo-bradesco" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-sulamerica">
            <img src="/images/logos_svgs/logo_sulamerica.svg" alt="SulAmerica" class="partners-page-hero-node-logo partners-page-hero-node-logo-sulamerica" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-omint">
            <img src="/images/logos_svgs/logo_omint.svg" alt="Omint" class="partners-page-hero-node-logo partners-page-hero-node-logo-omint" loading="lazy" width="700" height="700" />
          </div>
          <div class="partners-page-hero-node partners-page-hero-node-amil">
            <img src="/images/logos_svgs/logo_amil.svg" alt="Amil" class="partners-page-hero-node-logo partners-page-hero-node-logo-amil" loading="lazy" width="4096" height="4096" />
          </div>
        </div>

        <div class="partners-page-hero-rail">
          <div class="partners-page-hero-notes" aria-label="Diferenciais da rede de parcerias Klout">
            <p class="partners-page-hero-note">
              Operadoras rigorosamente selecionadas pela curadoria Klout
            </p>
            <p class="partners-page-hero-note">
              Acesso mais amplo a serviços médicos e melhores hospitais
            </p>
            <p class="partners-page-hero-note">
                Comparação feita para melhorar acesso sem inflar custo com benefícios que não serão usados
            </p>
          </div>

          <a
            href="#parceiro-alice"
            class="partners-page-hero-cta control-button"
            aria-label="Ir para a primeira operadora"
          >
            <span class="control-button__arrow control-button__arrow--right" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    </section>

    {partnerSections.map((partner) => (
      <section
        id={partner.id}
        class="partner-stage-section"
        data-stack-section
        data-stack-end="220%"
      >
        <div class="partner-stage-veil" aria-hidden="true"></div>
        <div class="partner-stage-track">
          <article class="partner-stage-panel partner-stage-panel-hero">
            <div class="partner-hero-shell">
              <div
                class="partner-hero-panel"
                style={`--partner-logo-image: url('${partner.logoMaskPath}'); --partner-logo-width: ${partner.logoWidth}; --partner-logo-max-height: ${partner.logoMaxHeight}; --partner-logo-width-mobile: ${partner.logoWidthMobile}; --partner-logo-max-height-mobile: ${partner.logoMaxHeightMobile}; --partner-panel-glow-a: ${partner.panelGlowA}; --partner-panel-glow-b: ${partner.panelGlowB}; --partner-panel-from: ${partner.panelFrom}; --partner-panel-mid: ${partner.panelMid}; --partner-panel-to: ${partner.panelTo}; --partner-panel-border: ${partner.panelBorder};`}
              >
                <div class="partner-hero-logo-shell">
                  <div
                    class="partner-hero-logo"
                    role="img"
                    aria-label={`Logo da operadora ${partner.name}`}
                  ></div>
                </div>
              </div>

              <aside class="partner-hero-meta" aria-label={`Informações da operadora ${partner.name}`}>
                <div class="partner-hero-meta-block">
                  <p class="partner-hero-meta-kicker">Leitura Klout</p>

                  <div class="partner-hero-meta-lines">
                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label partner-hero-meta-label-strong">Operadora:</span>
                      <span class="partner-hero-meta-value" data-value={partner.name}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>

                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label">Leitura:</span>
                      <span class="partner-hero-meta-value" data-value={partner.reading}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>

                    <p class="partner-hero-meta-row">
                      <span class="partner-hero-meta-label">Foco:</span>
                      <span class="partner-hero-meta-value" data-value={partner.focus}></span>
                      <span class="partner-hero-meta-cursor" aria-hidden="true"></span>
                    </p>
                  </div>
                </div>
              </aside>
            </div>

            <button
              type="button"
              class="partner-hero-slide-trigger control-button"
              aria-controls={partner.detailId}
              aria-expanded="false"
              aria-label={`Abrir aprofundamento da operadora ${partner.name}`}
            >
              <span
                class="partner-hero-slide-trigger-shape control-button__arrow control-button__arrow--right"
                aria-hidden="true"
              ></span>
            </button>
          </article>

          <article
            id={partner.detailId}
            class="partner-stage-panel partner-stage-panel-detail"
          >
            <div class="partner-detail-shell">
              <div class="partner-detail-body">
                <figure class="partner-detail-photo-frame">
                  <img
                    data-src="/images/partners/partner_01.webp"
                    alt={`Imagem editorial da seção da operadora ${partner.name}`}
                    class="partner-detail-photo"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>

                <div class="partner-detail-copy">
                  <p class="partner-detail-kicker">{`Base oficial ${partner.name}`}</p>
                  <h2 class="partner-detail-title">Cobertura com mais critério.</h2>
                  <p class="partner-detail-description">
                    {`A Klout analisa ${partner.name} sob a perspectiva de rede, modelo assistencial e elegibilidade para empresas, criando base para discussões mais claras sobre cobertura.`}
                  </p>
                </div>
              </div>

              <div class="partner-detail-footer">
                <button
                  type="button"
                  class="partner-detail-stage-back control-button"
                  aria-label="Voltar ao primeiro slide da seção"
                >
                  <span
                    class="partner-detail-stage-back-shape control-button__arrow control-button__arrow--left"
                    aria-hidden="true"
                  ></span>
                </button>

                {partner.nextId && (
                  <a href={`#${partner.nextId}`} class="partner-detail-skip">
                    Próxima operadora
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </article>
        </div>
      </section>
    ))}

    <section
      class="partners-page-closing"
      data-stack-section
      data-dark-section
      data-stack-end="150%"
      aria-labelledby="partners-page-closing-title"
    >
      <div class="partners-page-closing-shell">
        <p class="partners-page-closing-kicker">Curadoria Klout</p>
        <h2 id="partners-page-closing-title" class="partners-page-closing-title">
          Operadoras certas. Cobertura mais inteligente.
        </h2>
        <p class="partners-page-closing-description">
          Leitura consultiva para elevar rede, critério e previsibilidade nas condições do plano.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <FloatingNavbar />
</BaseLayout>

<script is:inline>
  window.addEventListener('load', () => {
    window.requestAnimationFrame(() => {
      const script = document.createElement('script');
      script.type = 'module';
      script.fetchPriority = 'low';
      script.async = true;
      script.src = '/scripts/partners-page.js';
      document.head.appendChild(script);
    });
  }, { once: true });
</script>

<style>
  .partner-stack-section {
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      hsl(214, 42%, 10%) 0%,
      hsl(214, 32%, 7%) 100%
    );
  }

  .partners-page-hero {
    --partners-hero-line-duration: 980ms;
    --partners-hero-main-duration: 1180ms;
    --partners-hero-node-duration: 1120ms;
    --partners-hero-rail-duration: 920ms;
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, hsla(42, 42%, 72%, 0.16) 0%, transparent 36%),
      radial-gradient(circle at 78% 22%, hsla(206, 52%, 68%, 0.16) 0%, transparent 28%),
      linear-gradient(
        180deg,
        hsl(42, 30%, 97.8%) 0%,
        hsl(206, 34%, 96.2%) 56%,
        hsl(210, 28%, 93.8%) 100%
      );
  }

  .partners-page-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .partners-page-geo-line {
    position: absolute;
    opacity: 0.34;
    transform: scaleX(1);
    transform-origin: 50% 50%;
    transition:
      opacity var(--partners-hero-line-duration) cubic-bezier(0.22, 1, 0.36, 1),
      transform var(--partners-hero-line-duration) cubic-bezier(0.22, 1, 0.36, 1);
  }

  .partners-page-geo-line-v1,
  .partners-page-geo-line-v2,
  .partners-page-geo-line-v3 {
    width: 1px;
    background: linear-gradient(
      180deg,
      hsla(214, 15%, 60%, 0) 0%,
      hsla(214, 15%, 60%, 0.2) 50%,
      hsla(214, 15%, 60%, 0) 100%
    );
  }

  .partners-page-geo-line-v1 {
    height: 56%;
    top: 18%;
    left: 11%;
  }

  .partners-page-geo-line-v2 {
    height: 64%;
    top: 12%;
    right: 18%;
  }

  .partners-page-geo-line-v3 {
    height: 42%;
    top: 34%;
    left: 58%;
  }

  .partners-page-geo-line-h1,
  .partners-page-geo-line-h2 {
    height: 1px;
    background: linear-gradient(
      90deg,
      hsla(214, 15%, 60%, 0) 0%,
      hsla(214, 15%, 60%, 0.16) 50%,
      hsla(214, 15%, 60%, 0) 100%
    );
  }

  .partners-page-geo-line-h1 {
    width: 42%;
    top: 33%;
    left: 0;
  }

  .partners-page-geo-line-h2 {
    width: 34%;
    bottom: 24%;
    right: 0;
  }

  .partners-page-hero-shell {
    width: 100%;
    min-height: 100vh;
    box-sizing: border-box;
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(4.9rem, 8.2vh, 6.6rem) clamp(1.5rem, 5vw, 4.5rem) clamp(2.4rem, 4.2vh, 3rem);
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(20rem, 0.98fr);
    align-items: center;
    gap: clamp(1.5rem, 4.5vw, 4rem);
    position: relative;
    z-index: 1;
  }

  .partners-page-hero-copy {
    display: grid;
    gap: 0;
    align-content: center;
    max-width: 32rem;
  }

  .partners-page-hero-title {
    margin: 0;
    max-width: 8ch;
    font-family: var(--font-serif);
    font-size: clamp(3.9rem, 6.8vw, 6.8rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.075em;
    color: hsl(214, 42%, 14%);
  }

  .partners-page-hero-visual {
    position: relative;
    isolation: isolate;
    justify-self: end;
    width: min(100%, 34rem, calc(100vh - 10.4rem));
    aspect-ratio: 1 / 1;
    min-height: 0;
    max-height: calc(100vh - 10.4rem);
    display: grid;
    place-items: center;
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transform-origin: 50% 50%;
    transition:
      opacity var(--partners-hero-main-duration) cubic-bezier(0.22, 1, 0.36, 1),
      transform var(--partners-hero-main-duration) cubic-bezier(0.22, 1, 0.36, 1);
  }

  .partners-page-hero-map {
    --partners-map-mask: url('/images/brasil.svg');
    position: relative;
    z-index: 0;
    isolation: isolate;
    width: min(115%, 39.1rem);
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(circle at 30% 18%, hsla(0, 0%, 100%, 0.98) 0%, hsla(0, 0%, 100%, 0.62) 18%, transparent 42%),
      radial-gradient(circle at 72% 78%, hsla(214, 22%, 50%, 0.16) 0%, transparent 34%),
      linear-gradient(142deg, hsl(42, 22%, 96%) 0%, hsl(42, 18%, 89%) 38%, hsl(210, 16%, 76%) 100%);
    -webkit-mask-image: var(--partners-map-mask);
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    -webkit-mask-size: contain;
    mask-image: var(--partners-map-mask);
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    transform: scale(1);
    transform-origin: 50% 50%;
    transition: transform calc(var(--partners-hero-main-duration) + 220ms) cubic-bezier(0.22, 1, 0.36, 1);
    filter:
      drop-shadow(-4px -4px 0 hsla(0, 0%, 100%, 0.9))
      drop-shadow(3px 4px 0 hsla(42, 16%, 74%, 0.48))
      drop-shadow(11px 16px 20px hsla(214, 24%, 20%, 0.18))
      drop-shadow(24px 28px 42px hsla(214, 30%, 14%, 0.08));
  }

  .partners-page-hero-map::before,
  .partners-page-hero-map::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    -webkit-mask-image: var(--partners-map-mask);
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    -webkit-mask-size: contain;
    mask-image: var(--partners-map-mask);
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
  }

  .partners-page-hero-map::before {
    background:
      linear-gradient(145deg, hsla(0, 0%, 100%, 0.7) 0%, transparent 28%),
      linear-gradient(315deg, hsla(214, 28%, 20%, 0.16) 0%, transparent 50%),
      repeating-linear-gradient(
        112deg,
        hsla(214, 24%, 34%, 0.028) 0 1px,
        transparent 1px 9px
      );
    mix-blend-mode: multiply;
    opacity: 0.82;
    z-index: 1;
  }

  .partners-page-hero-map::after {
    background:
      radial-gradient(circle at 36% 26%, hsla(0, 0%, 100%, 0.38) 0%, transparent 26%),
      linear-gradient(135deg, transparent 0%, hsla(214, 24%, 24%, 0.11) 100%);
    mix-blend-mode: soft-light;
    opacity: 0.9;
    z-index: 2;
  }

  .partners-page-hero-node {
    position: absolute;
    z-index: 3;
    width: 4.35rem;
    height: 4.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(circle at 20% 14%, hsla(208, 46%, 54%, 0.18) 0%, transparent 18%),
      radial-gradient(circle at 82% 86%, hsla(220, 62%, 10%, 0.3) 0%, transparent 30%),
      linear-gradient(160deg, hsl(211, 34%, 32%) 0%, hsl(214, 38%, 24%) 42%, hsl(218, 44%, 17%) 100%);
    border: 1px solid hsla(210, 32%, 88%, 0.08);
    box-shadow:
      0 18px 38px hsla(214, 34%, 8%, 0.22),
      0 12px 28px hsla(214, 30%, 10%, 0.16),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.07),
      inset 0 -14px 20px hsla(220, 52%, 8%, 0.16);
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transition:
      opacity var(--partners-hero-node-duration) cubic-bezier(0.16, 1, 0.3, 1),
      transform var(--partners-hero-node-duration) cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.28s ease;
  }

  .partners-page-hero-node::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(125deg, hsla(0, 0%, 100%, 0.06) 0%, transparent 18%, transparent 56%, hsla(220, 48%, 10%, 0.11) 100%),
      radial-gradient(circle at 22% 12%, hsla(0, 0%, 100%, 0.08) 0%, transparent 20%),
      radial-gradient(circle at 72% 58%, hsla(220, 48%, 10%, 0.12) 0%, transparent 24%),
