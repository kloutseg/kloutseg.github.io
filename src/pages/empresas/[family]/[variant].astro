---
import CampaignLanding from '../../../components/campaign/CampaignLanding.astro';
import ReajusteExperiment from '../../../components/campaign/ReajusteExperiment.astro';
import { campaignLandings, type CampaignLanding as CampaignLandingData } from '../../../lib/campaign-landings';

export function getStaticPaths() {
  return campaignLandings.map((landing) => ({
    params: { family: landing.family, variant: landing.variant },
    props: { landing },
  }));
}

interface Props { landing: CampaignLandingData }
const { landing } = Astro.props;
const isReajusteExperiment = landing.family === 'custos' && landing.variant === 'reajuste';
---

{isReajusteExperiment ? <ReajusteExperiment landing={landing} /> : <CampaignLanding landing={landing} />}
