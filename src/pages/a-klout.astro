---
import BaseLayout from '../layouts/Base.astro';
import FloatingNavbar from '../components/navbar/FloatingNavbar.svelte';
import SectionStacking from '../components/SectionStacking.svelte';
import Footer from '../components/Footer.svelte';
import BackToTop from '../components/BackToTop.astro';
import { kloutAboutSchema, kloutOrganizationId } from '../lib/schema';

const siteUrl = 'https://www.kloutseguros.com.br';
const kloutLinkedinUrl = 'https://www.linkedin.com/company/klout-seguros';

type LeadershipMember = {
  name: string;
  jobTitle: string;
  email: string;
  telephone: string;
  phoneLabel?: string;
  linkedin?: string;
  summary?: string;
  image: string;
  imageAlt: string;
  slug: string;
  group: 'direction' | 'management';
  placeholder?: boolean;
};

const leadershipTeam: LeadershipMember[] = [
  {
    name: 'Kennedy Souza',
    jobTitle: 'CEO',
    email: 'kenny@kloutseguros.com.br',
    telephone: '+55-11-93244-4327',
    phoneLabel: 'WhatsApp',
    linkedin: 'https://www.linkedin.com/in/kennedy-souza-25aa6b212/',
    summary: '',
    image: '/images/team/c-levels/ceo_kennedy-souza/kennedy-souza_ceo_klout-seguros.webp',
    imageAlt: 'Retrato de Kennedy Souza, CEO da Klout',
    slug: 'kennedy-souza',
    group: 'direction',
  },
  {
    name: 'Vitor Ribeiro',
    jobTitle: 'COO',
    email: 'vitor@kloutseguros.com.br',
    telephone: '+55-11-99833-1320',
    phoneLabel: 'WhatsApp',
    linkedin: 'https://www.linkedin.com/in/vitor-santos-9a054b16b',
    summary: '',
    image: '/images/team/c-levels/coo_vitor-ribeiro/vitor-ribeiro_coo.webp',
    imageAlt: 'Retrato de Vitor Ribeiro, COO da Klout',
    slug: 'vitor-ribeiro',
    group: 'direction',
  },
  {
    name: 'Carlos Cantilha',
    jobTitle: 'CLO',
    email: 'carlos.cantilha@kloutseguros.com.br',
    telephone: '+55-11-93065-5559',
    phoneLabel: 'WhatsApp',
    linkedin: 'https://www.linkedin.com/in/carlos-cantilha-56a028421',
    summary: '',
    image: '/images/team/c-levels/clo_carlos-cantilha/carlos-cantilha_clo.webp',
    imageAlt: 'Retrato de Carlos Cantilha, CLO da Klout',
    slug: 'carlos-cantilha',
    group: 'direction',
  },
  {
    name: 'Guilherme Lucas',
    jobTitle: 'Gerente de Relacionamento',
    email: 'guilherme.lucas@kloutseguros.com.br',
    telephone: '+55-11-93712-1994',
    phoneLabel: 'Telefone',
    linkedin: '',
    summary: '',
    image: '/images/team/managers/gerente-de-relacionamento_guilherme-lucas/guilherme-lucas_gerente-de-relacionamento.webp',
    imageAlt: 'Retrato de Guilherme Lucas, Gerente de Relacionamento da Klout',
    slug: 'guilherme-lucas',
    group: 'management',
  },
  {
    name: 'Felipe Bandechi',
    jobTitle: 'Gerente Comercial',
    email: 'felipe.bandechi@kloutseguros.com.br',
    telephone: '+55-11-97142-1515',
    phoneLabel: 'WhatsApp',
    linkedin: '',
    summary: '',
    image: '/images/team/managers/gerente-comercial_felipe-bandechi/felipe-bandechi_gerente-comercial.webp',
    imageAlt: 'Retrato de Felipe Bandechi, Gerente Comercial da Klout',
    slug: 'felipe-bandechi',
    group: 'management',
  },
  {
    name: 'Augusto Cavalheiro',
    jobTitle: 'Gerente Comercial',
    email: 'augusto.cavalheiro@kloutseguros.com.br',
    telephone: '+55-11-93277-9317',
    phoneLabel: 'WhatsApp',
    linkedin: '',
    summary: '',
    image: '/images/team/managers/gerente-comercial_augusto-cavalheiro/augusto-cavalheiro_gerente-comercial.webp',
    imageAlt: 'Retrato de Augusto Cavalheiro, Gerente Comercial da Klout',
    slug: 'augusto-cavalheiro',
    group: 'management',
  },
  {
    name: 'Mariana Trajano',
    jobTitle: 'Gerente Comercial',
    email: 'mariana@kloutseguros.com.br',
    telephone: '+55-11-91328-6299',
    phoneLabel: 'WhatsApp',
    linkedin: '',
    summary: '',
    image: '/images/team/managers/gerente-comercial_mariana-trajano/mariana-trajano_gerente-comercial.webp',
    imageAlt: 'Retrato de Mariana Trajano, Gerente Comercial da Klout',
    slug: 'mariana-trajano',
    group: 'management',
  },
  {
    name: 'Julia Camargo',
    jobTitle: 'Gerente de Implantação',
    email: 'julia.camargo@kloutseguros.com.br',
    telephone: '+55-11-97861-5526',
    phoneLabel: 'WhatsApp',
    linkedin: '',
    summary: '',
    image: '/images/team/managers/gerente-de-implantação_julia-camargo/julia-camargo_gerente-de-implantação.webp',
    imageAlt: 'Retrato de Julia Camargo, Gerente de Implantação da Klout',
    slug: 'julia-camargo',
    group: 'management',
  },
];

const directionTeam = leadershipTeam.filter((member) => member.group === 'direction');
const managementTeamOrder = [
  'augusto-cavalheiro',
  'mariana-trajano',
  'felipe-bandechi',
  'julia-camargo',
  'guilherme-lucas',
];
const managementTeam = leadershipTeam
  .filter((member) => member.group === 'management')
  .sort((first, second) => managementTeamOrder.indexOf(first.slug) - managementTeamOrder.indexOf(second.slug));
const publishedLeadershipTeam = leadershipTeam.filter((member) => !member.placeholder);

const leadershipPersonNodes = publishedLeadershipTeam.map((member) => ({
  '@type': 'Person',
  '@id': `${siteUrl}/a-klout#${member.slug}`,
  name: member.name,
  jobTitle: member.jobTitle,
  email: `mailto:${member.email}`,
  telephone: member.telephone,
  url: `${siteUrl}/a-klout#${member.slug}`,
  ...(member.image && {
    image: member.image.startsWith('http') ? member.image : `${siteUrl}${member.image}`,
  }),
  ...(member.linkedin && { sameAs: [member.linkedin] }),
  ...(member.summary && { description: member.summary }),
  worksFor: {
    '@id': kloutOrganizationId,
  },
}));

const aboutStructuredData = leadershipPersonNodes.length
  ? {
      ...kloutAboutSchema,
      '@graph': [
        ...(kloutAboutSchema['@graph'] ?? []).map((node) => {
          if (node['@id'] !== kloutOrganizationId) return node;

          return {
            ...node,
            employee: leadershipPersonNodes.map((member) => ({ '@id': member['@id'] })),
          };
        }),
        ...leadershipPersonNodes,
      ],
    }
  : kloutAboutSchema;

const addressItems = [
  {
    label: 'Unidade base',
    value: 'R. Sena Madureira, 151 - Vila Mariana, São Paulo - SP, 04021-050',
  },
  {
    label: 'Atendimento',
    value: 'Presencial com hora marcada',
  },
  {
    label: 'Demais pontos',
    value: 'R. da Quitanda, 96 - Centro Histórico de São Paulo, São Paulo - SP, 01012-010',
    secondary: true,
  },
  {
    value: 'R. Sen. Fonseca, 715 - Centro, Jundiaí - SP, 13201-017',
    secondary: true,
  },
];
---

<BaseLayout
  title="A Klout"
  description="Conheça a Klout, consultoria especializada em planos de saúde que une análise técnica, curadoria e orientação estratégica."
  criticalImage="/images/about_klout_hero_consultive.webp"
  criticalImageSrcset="/images/about_klout_hero_consultive-768.webp 768w, /images/about_klout_hero_consultive-1024.webp 1024w, /images/about_klout_hero_consultive.webp 1536w"
  criticalImageSizes="100vw"
  structuredData={aboutStructuredData}
>
  <FloatingNavbar client:media="(min-width: 769px)" />
  <SectionStacking client:load />

  <main id="main-content">
    <section id="a-klout" class="about-klout-hero" data-stack-section data-dark-section>
      <div class="about-klout-hero-media">
        <img
          src="/images/about_klout_hero_consultive.webp"
          srcset="/images/about_klout_hero_consultive-768.webp 768w, /images/about_klout_hero_consultive-1024.webp 1024w, /images/about_klout_hero_consultive.webp 1536w"
          sizes="100vw"
          alt="Conversa consultiva em ambiente acolhedor para orientação em saúde"
          class="about-klout-hero-image"
          loading="eager"
          fetchpriority="high"
          width="1536"
          height="1024"
        />
        <div class="about-klout-hero-overlay"></div>
      </div>

      <div class="about-klout-hero-shell">
        <p class="about-klout-kicker section-side-kicker section-side-kicker-light">A Klout</p>

        <div class="about-klout-hero-copy">
          <h1 class="about-klout-hero-title">
            A Klout existe para influenciar decisões mais inteligentes em saúde.
          </h1>
          <p class="about-klout-hero-description">
            Estamos presentes em São Paulo, com operação real, atendimento próximo e assistência personalizada para famílias e empresas.
          </p>
        </div>
      </div>
    </section>

    <section class="about-klout-section about-klout-proof" data-stack-section>
      <div class="about-klout-shell">
        <p class="about-klout-side-kicker section-side-kicker">Presença real</p>

        <div class="about-klout-proof-grid">
          <div class="about-klout-proof-lead">
            <h2 class="about-klout-proof-title">Não começamos pela venda. Começamos pela leitura.</h2>
          </div>

          <div class="about-klout-proof-copy">
            <div class="about-klout-proof-lines" aria-label="Apresentação da Klout">
              <p>Somos técnicos e transparentes. Lemos apólices com rigor e identificamos o que realmente altera cobertura, aderência e eficiência.</p>
              <p>Transparência, aqui, significa uma coisa: dizer com clareza o que faz sentido e o que não faz, inclusive quando a melhor decisão é continuar com a sua apólice.</p>
              <p>Atendemos no escritório, na empresa ou na sua casa, com hora marcada.</p>
            </div>

            <div class="about-klout-proof-actions">
              <a href="/analise" class="about-klout-proof-cta">
                Agendar conversa
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="about-klout-section about-klout-team" aria-labelledby="about-klout-team-title">
      <div class="about-klout-shell about-klout-team-shell">
        <div class="about-klout-team-heading">
          <p class="about-klout-side-kicker section-side-kicker">Liderança</p>
          <div class="about-klout-team-heading-copy">
            <h2 id="about-klout-team-title" class="about-klout-team-title">Atendimento técnico e acessível.</h2>
            <p class="about-klout-team-description">
              A liderança da Klout mantém canais diretos para orientar decisões, acompanhar casos individualmente e fornecer um atendimento próximo.
            </p>
          </div>
        </div>

        <div class="about-klout-team-groups">
          <div class="about-klout-team-group">
            <p class="about-klout-team-group-label">Direção</p>
            <div class="about-klout-team-grid about-klout-team-grid-direction" aria-label="Direção da Klout">
              {directionTeam.map((member, index) => (
                <article id={member.slug} class:list={['about-klout-team-card', 'about-klout-team-card-direction', member.placeholder && 'about-klout-team-card-placeholder']}>
                  <figure class="about-klout-team-photo-frame">
                    {member.image ? (
                      <img
                        src={member.image}
                        alt={member.imageAlt || `Retrato de ${member.name}`}
                        class="about-klout-team-photo"
                        loading="lazy"
                        width="720"
                        height="900"
                      />
                    ) : (
                      <div class="about-klout-team-photo-placeholder" aria-hidden="true">
                        <span>{String(index + 1).padStart(2, '0')}</span>
                      </div>
                    )}
                  </figure>

                  <div class="about-klout-team-card-copy">
                    <div class="about-klout-team-identity">
                      <h3 class="about-klout-team-name">{member.name}</h3>
                      <p class="about-klout-team-role">{member.jobTitle}</p>
                    </div>

                    {member.summary && <p class="about-klout-team-summary">{member.summary}</p>}

                    <div class="about-klout-team-links" aria-label={`Canais de contato de ${member.name}`}>
                      {member.email && (
                        <a href={`mailto:${member.email}`} class="about-klout-team-contact-link">Email</a>
                      )}
                      {member.telephone && (
                        <a href={`tel:${member.telephone.replace(/[^\d+]/g, '')}`} class="about-klout-team-contact-link">{member.phoneLabel || 'Telefone'}</a>
                      )}
                      <a
                        href={member.linkedin || kloutLinkedinUrl}
                        class="about-klout-team-linkedin-link"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={member.linkedin ? `LinkedIn de ${member.name}` : 'LinkedIn da Klout'}
                        title={member.linkedin ? `LinkedIn de ${member.name}` : 'LinkedIn da Klout'}
                      >
                        <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                          <path d="M26.111,3H5.889c-1.595,0-2.889,1.293-2.889,2.889V26.111c0,1.595,1.293,2.889,2.889,2.889H26.111c1.595,0,2.889-1.293,2.889-2.889V5.889c0-1.595-1.293-2.889-2.889-2.889ZM10.861,25.389h-3.877V12.87h3.877v12.519Zm-1.957-14.158c-1.267,0-2.293-1.034-2.293-2.31s1.026-2.31,2.293-2.31,2.292,1.034,2.292,2.31-1.026,2.31-2.292,2.31Zm16.485,14.158h-3.858v-6.571c0-1.802-.685-2.809-2.111-2.809-1.551,0-2.362,1.048-2.362,2.809v6.571h-3.718V12.87h3.718v1.686s1.118-2.069,3.775-2.069,4.556,1.621,4.556,4.975v7.926Z" fill-rule="evenodd"></path>
                        </svg>
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <div class="about-klout-team-group">
            <p class="about-klout-team-group-label">Gestão</p>
            <div class="about-klout-team-grid about-klout-team-grid-management" aria-label="Gestão da Klout">
              {managementTeam.map((member, index) => (
                <article id={member.slug} class:list={['about-klout-team-card', 'about-klout-team-card-management', member.placeholder && 'about-klout-team-card-placeholder']}>
                  <figure class="about-klout-team-photo-frame">
                    {member.image ? (
                      <img
                        src={member.image}
                        alt={member.imageAlt || `Retrato de ${member.name}`}
                        class="about-klout-team-photo"
                        loading="lazy"
                        width="420"
                        height="525"
                      />
                    ) : (
                      <div class="about-klout-team-photo-placeholder" aria-hidden="true">
                        <span>{String(index + directionTeam.length + 1).padStart(2, '0')}</span>
                      </div>
                    )}
                  </figure>

                  <div class="about-klout-team-card-copy">
                    <div class="about-klout-team-identity">
                      <h3 class="about-klout-team-name">{member.name}</h3>
                      <p class="about-klout-team-role">{member.jobTitle}</p>
                    </div>

                    {member.summary && <p class="about-klout-team-summary">{member.summary}</p>}

                    <div class="about-klout-team-links" aria-label={`Canais de contato de ${member.name}`}>
                      {member.email && (
                        <a href={`mailto:${member.email}`} class="about-klout-team-contact-link">Email</a>
                      )}
                      {member.telephone && (
                        <a href={`tel:${member.telephone.replace(/[^\d+]/g, '')}`} class="about-klout-team-contact-link">{member.phoneLabel || 'Telefone'}</a>
                      )}
                      <a
                        href={member.linkedin || kloutLinkedinUrl}
                        class="about-klout-team-linkedin-link"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={member.linkedin ? `LinkedIn de ${member.name}` : 'LinkedIn da Klout'}
                        title={member.linkedin ? `LinkedIn de ${member.name}` : 'LinkedIn da Klout'}
                      >
                        <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                          <path d="M26.111,3H5.889c-1.595,0-2.889,1.293-2.889,2.889V26.111c0,1.595,1.293,2.889,2.889,2.889H26.111c1.595,0,2.889-1.293,2.889-2.889V5.889c0-1.595-1.293-2.889-2.889-2.889ZM10.861,25.389h-3.877V12.87h3.877v12.519Zm-1.957-14.158c-1.267,0-2.293-1.034-2.293-2.31s1.026-2.31,2.293-2.31,2.292,1.034,2.292,2.31-1.026,2.31-2.292,2.31Zm16.485,14.158h-3.858v-6.571c0-1.802-.685-2.809-2.111-2.809-1.551,0-2.362,1.048-2.362,2.809v6.571h-3.718V12.87h3.718v1.686s1.118-2.069,3.775-2.069,4.556,1.621,4.556,4.975v7.926Z" fill-rule="evenodd"></path>
                        </svg>
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="about-klout-section about-klout-gallery">
      <div class="about-klout-shell">
        <div class="about-klout-units-grid">
          <figure class="about-klout-units-photo-frame">
            <picture>
              <source
                media="(min-width: 1024px)"
                srcset="/images/office_units-desktop.webp 1774w"
                sizes="50vw"
                type="image/webp"
              />
              <source
                media="(min-width: 1024px)"
                srcset="/images/office_units.png 1774w"
                sizes="50vw"
                type="image/png"
              />
              <source
                srcset="/images/office_units-700.webp 700w, /images/office_units-960.webp 960w, /images/office_units.webp 1774w"
                sizes="100vw"
                type="image/webp"
              />
              <img
                src="/images/office_units.png"
                alt="Ambiente de escritório contemporâneo da Klout para reuniões presenciais"
                class="about-klout-units-photo"
                loading="lazy"
                width="1774"
                height="887"
              />
            </picture>
          </figure>

          <div class="about-klout-units-copy">
            <p class="about-klout-side-kicker section-side-kicker">Unidades da Klout</p>

            <div class="about-klout-address-list" aria-label="Pontos de atendimento da Klout">
              {addressItems.map((item) => (
                <article class="about-klout-address-item">
                  {item.label && <p class="about-klout-address-label">{item.label}</p>}
                  <p class:list={['about-klout-address-value', item.secondary && 'about-klout-address-value-secondary']}>{item.value}</p>
                </article>
              ))}
            </div>

          </div>
        </div>
      </div>
    </section>

    <section class="about-klout-section about-klout-cta" data-dark-section>
      <div class="about-klout-shell about-klout-cta-shell">
        <p class="about-klout-cta-kicker">Conversar com a Klout</p>
        <h2 class="about-klout-cta-title">
          Se você procura critério, leitura técnica e transparência, podemos conversar.
        </h2>
        <a href="/analise" class="about-klout-cta-link">
          Agendar conversa
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <BackToTop />
</BaseLayout>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion =
    typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    window.addEventListener('load', () => {
      const hero = document.querySelector('.about-klout-hero');
      if (!hero) return;

      const heroImage = hero.querySelector('.about-klout-hero-image');
      const heroOverlay = hero.querySelector('.about-klout-hero-overlay');
      const heroKicker = hero.querySelector('.about-klout-kicker');
      const heroTitle = hero.querySelector('.about-klout-hero-title');
      const heroDescription = hero.querySelector('.about-klout-hero-description');
      const arrivedViaPageTransition =
        document.documentElement.classList.contains('page-transition-enter');

      if (arrivedViaPageTransition) {
        gsap.set([heroKicker, heroTitle, heroDescription], {
          autoAlpha: 1,
          y: 0
        });

        gsap.set(heroImage, {
          scale: 1,
          autoAlpha: 1
        });

        gsap.set(heroOverlay, {
          autoAlpha: 1
        });

        return;
      }

      gsap.set([heroKicker, heroTitle, heroDescription], {
        autoAlpha: 0,
        y: 42
      });

      gsap.set(heroImage, {
        scale: 1.14,
        autoAlpha: 0.58
      });

      gsap.set(heroOverlay, {
        autoAlpha: 0.18
      });

      const tl = gsap.timeline({
        defaults: { ease: 'power2.out' }
      });

      tl.to(heroImage, {
        scale: 1,
        autoAlpha: 1,
        duration: 2.8,
        ease: 'power3.out'
      })
        .to(heroOverlay, {
          autoAlpha: 1,
          duration: 2.2,
          ease: 'power2.out'
        }, 0.18)
        .to(heroKicker, {
          autoAlpha: 1,
          y: 0,
          duration: 1.15,
          ease: 'power3.out'
        }, 0.92)
        .to(heroTitle, {
          autoAlpha: 1,
          y: 0,
          duration: 1.45,
          ease: 'power3.out'
        }, 1.02)
        .to(heroDescription, {
          autoAlpha: 1,
          y: 0,
          duration: 1.2,
          ease: 'power3.out'
        }, 1.42);
    }, { once: true });
  }
</script>

<style>
  .about-klout-hero {
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    background: hsl(214, 48%, 7%);
  }

  .about-klout-hero-media,
  .about-klout-hero-image,
  .about-klout-hero-overlay {
    position: absolute;
    inset: 0;
  }

  .about-klout-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.56) saturate(0.88) contrast(0.94);
  }

  .about-klout-hero-overlay {
    background:
