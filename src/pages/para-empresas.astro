---
import BaseLayout from '../layouts/Base.astro';
import FloatingNavbar from '../components/navbar/FloatingNavbar.svelte';
import SectionStacking from '../components/SectionStacking.svelte';
import Footer from '../components/Footer.svelte';
import BackToTop from '../components/BackToTop.astro';
import IntroQaRotator from '../components/for-you/IntroQaRotator.svelte';

const qaCases = [
  {
    eyebrow: 'Caso 01',
    question:
      'Estamos crescendo, mas o benefício atual não acompanha a senioridade das contratações que queremos atrair.',
    answer:
      'Analisamos o perfil da sua empresa e do mercado para reposicionar o benefício com mais aderência, percepção de valor e consistência financeira.',
    cta: 'Estruturar benefício corporativo',
    href: '/analise',
  },
  {
    eyebrow: 'Caso 02',
    question:
      'Nosso plano virou fonte de debate interno: rede fraca, pouca previsibilidade e dificuldade para justificar custo.',
    answer:
      'Revemos quais hospitais e laboratórios entram na rede, como o reajuste funciona, onde o contrato atual perde força e o que pode ser corrigido sem trocar custo por complexidade.',
    cta: 'Revisar contrato atual',
    href: '/analise',
  },
  {
    eyebrow: 'Caso 03',
    question:
      'Queremos oferecer algo melhor sem inflar os custos ou escolher entre opções superficiais do mercado.',
    answer:
      'Comparamos o que ajuda a atrair e reter grandes talentos com o que a empresa consegue pagar sem apertar o caixa no médio prazo. Só depois definimos operadora, linha e formato do benefício.',
    cta: 'Desenhar estratégia',
    href: '/analise',
  },
];
---

<BaseLayout
  title="Para Empresas | Klout"
  description="A Klout apoia empresas na análise de contratos, custos, rede credenciada e alternativas para planos de saúde corporativos."
  criticalImage="/images/office_hero.webp"
  criticalImageSrcset="/images/office_hero-640.webp 640w, /images/office_hero-960.webp 960w, /images/office_hero.webp 1920w"
  criticalImageSizes="100vw"
>
  <FloatingNavbar client:media="(min-width: 769px)" />
  <SectionStacking client:load />

  <main id="main-content">
    <section id="empresas" class="companies-hero" data-stack-section data-dark-section>
      <p class="hero-kicker section-side-kicker section-side-kicker-light">Para empresas</p>
      <div class="hero-media">
        <img
          src="/images/office_hero.webp"
          srcset="/images/office_hero-640.webp 640w, /images/office_hero-960.webp 960w, /images/office_hero.webp 1920w"
          sizes="100vw"
          alt="Escritório contemporâneo com ambiente executivo para decisões corporativas"
          class="hero-image"
          loading="eager"
          fetchpriority="high"
          width="1920"
          height="1280"
        />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="hero-copy-main">
          <h1 class="hero-title">Estratégia consultiva para benefícios corporativos</h1>
        </div>

        <div class="hero-copy-side">
          <div class="hero-description-shell">
            <p class="hero-description">
              Estruturamos decisões de saúde corporativa com leitura crítica de rede, custo, retenção e posicionamento para que o benefício acompanhe a ambição da empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="companies-section section-intro" data-stack-section>
      <div class="section-intro-kicker section-side-kicker">Leitura corporativa</div>
      <div class="section-shell">
        <div class="section-grid">
          <div class="section-copy">
            <h2 class="section-title">Benefício baseado em contexto, não em tabela.</h2>
            <p class="section-text">
                Direcionamos o foco em hospitais, laboratórios e clínicas que pesam de verdade na decisão do time, sem transformar o contrato em custo difícil de manter.
            </p>
          </div>
          <IntroQaRotator client:load items={qaCases} tone="business" />
        </div>
      </div>
    </section>

    <section class="companies-section section-steps" data-stack-section data-stack-end="260%">
      <p class="eyebrow criteria-kicker section-side-kicker">O Processo</p>
      <div class="section-shell steps-shell">
        <div class="steps-layout">
          <div class="steps-grid">
            <article class="step-card step-card-primary">
              <div class="step-meta">
                <span class="step-index">01</span>
              </div>
              <h3 class="step-title">Leitura da empresa</h3>
              <p class="step-text">Entendemos tamanho da equipe, perfil das vidas, fase da empresa e teto orçamentário.</p>
            </article>

            <article class="step-card step-card-secondary">
              <div class="step-meta">
                <span class="step-index">02</span>
              </div>
              <h3 class="step-title">Leitura das opções</h3>
              <p class="step-text">Comparamos quais hospitais e laboratórios entram na rede, como funcionam acomodação, coparticipação e reajuste, e quais facilidades de uso realmente fazem diferença no dia a dia.</p>
            </article>

            <article class="step-card step-card-accent">
              <div class="step-meta">
                <span class="step-index">03</span>
              </div>
              <h3 class="step-title">Leitura Final</h3>
              <p class="step-text">Você recebe uma recomendação clara para decidir internamente e negociar melhor.</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="companies-section section-criteria" data-stack-section>
      <p class="eyebrow criteria-kicker section-side-kicker">O que avaliamos</p>
      <div class="section-shell criteria-shell">
        <div class="criteria-copy">
          <div class="criteria-copy-head">
            <h2 class="criteria-title">O benefício que funciona na prática</h2>
          </div>

          <div class="criteria-list">
            <article class="criteria-item">
              <h3>Rede útil</h3>
              <p>Acesso a hospitais, clínicas e laboratórios de ponta que o time reconhece como melhoria real.</p>
            </article>

            <article class="criteria-item">
              <h3>Contrato controlado</h3>
              <p>Coparticipação, reajuste, carências, acomodação e regras conhecidas antes de fechar.</p>
            </article>

            <article class="criteria-item">
              <h3>Escala viável e previsível</h3>
              <p>Custo que cabe hoje e permanece aderente à medida em que a empresa cresce.</p>
            </article>
          </div>
        </div>

        <figure class="criteria-figure">
          <div class="criteria-image-frame">
            <img
              src="/images/office_03.webp"
              srcset="/images/office_03-700.webp 700w, /images/office_03-900.webp 900w, /images/office_03.webp 1023w"
              sizes="(max-width: 768px) 88vw, 560px"
              alt="Equipe em reunião corporativa avaliando benefícios de saúde"
              class="criteria-image"
              loading="lazy"
              width="1023"
              height="1537"
            />
            <div class="criteria-image-shade"></div>
          </div>
        </figure>
      </div>
    </section>

    <section class="companies-section section-cta" data-dark-section>
      <p class="eyebrow section-side-kicker section-side-kicker-light">Próximo passo</p>
      <div class="section-shell cta-shell">
        <div class="cta-box">
          <h2 class="section-title cta-title">Se o benefício influencia retenção e cultura, ele merece uma leitura estratégica.</h2>
          <p class="section-text cta-text">
              Converse com a Klout e saia com uma direção mais clara para RH, liderança e financeiro.
          </p>
          <a href="/analise" class="companies-button">
            Iniciar conversa
            <svg class="companies-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BackToTop />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion =
    typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    window.addEventListener('load', () => {
      const hero = document.querySelector('.companies-hero');
      if (!hero) return;

      const canAnimateHeroIntro = window.matchMedia('(min-width: 769px)').matches;

      if (canAnimateHeroIntro) {
        const heroImage = hero.querySelector('.hero-image');
        const heroOverlay = hero.querySelector('.hero-overlay');
        const heroKicker = hero.querySelector('.hero-kicker');
        const heroTitle = hero.querySelector('.hero-title');
        const heroDescriptionShell = hero.querySelector('.hero-description-shell');

        gsap.set([heroKicker, heroTitle, heroDescriptionShell], {
          autoAlpha: 0,
          y: 42
        });

        gsap.set(heroImage, {
          scale: 1.14,
          autoAlpha: 0.58
        });

        gsap.set(heroOverlay, {
          autoAlpha: 0.18
        });

        const tl = gsap.timeline({
          defaults: { ease: 'power2.out' }
        });

        tl.to(heroImage, {
          scale: 1,
          autoAlpha: 1,
          duration: 2.8,
          ease: 'power3.out'
        })
          .to(heroOverlay, {
            autoAlpha: 1,
            duration: 2.2,
            ease: 'power2.out'
          }, 0.18)
          .to(heroKicker, {
            autoAlpha: 1,
            y: 0,
            duration: 1.15,
            ease: 'power3.out'
          }, 0.92)
          .to(heroTitle, {
            autoAlpha: 1,
            y: 0,
            duration: 1.45,
            ease: 'power3.out'
          }, 1.02)
          .to(heroDescriptionShell, {
            autoAlpha: 1,
            y: 0,
            duration: 1.2,
            ease: 'power3.out'
          }, 1.42);
      }

      const stepsSection = document.querySelector('.section-steps');
      const stepCards = stepsSection?.querySelectorAll('.step-card');

      if (stepsSection && stepCards?.length) {
        const mm = gsap.matchMedia();

        mm.add('(min-width: 769px)', () => {
          gsap.set(stepCards, {
            autoAlpha: 0,
            y: 72,
            rotateX: -8,
            transformOrigin: '50% 100%'
          });

          const stepsTl = gsap.timeline({
            defaults: { ease: 'power3.out' },
            scrollTrigger: {
              trigger: stepsSection,
              start: 'top 62%',
              end: 'top 12%',
              scrub: 0.65
            }
          });

          stepsTl
            .to(stepCards, {
              autoAlpha: 1,
              y: 0,
              rotateX: 0,
              duration: 0.86,
              stagger: 0.12
            }, 0);
        });

        mm.add('(max-width: 768px)', () => {
          gsap.set(stepCards, {
            autoAlpha: 0,
            y: 36
          });

          gsap.to(stepCards, {
            autoAlpha: 1,
            y: 0,
            duration: 0.72,
            stagger: 0.12,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: stepsSection,
              start: 'top 64%'
            }
          });
        });
      }
    }, { once: true });
  }
</script>

<style>
  .companies-hero {
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    background: hsl(214, 18%, 10%);
  }

  .hero-media,
  .hero-image,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 24%;
    filter: saturate(0.94) contrast(1.02) brightness(0.84);
  }

  .hero-overlay {
    background:
      linear-gradient(180deg, hsla(214, 30%, 8%, 0.08) 0%, hsla(214, 30%, 8%, 0.16) 30%, hsla(214, 30%, 8%, 0.72) 100%),
      linear-gradient(90deg, hsla(214, 35%, 8%, 0.74) 0%, hsla(214, 35%, 8%, 0.34) 42%, hsla(214, 35%, 8%, 0.16) 100%),
      radial-gradient(circle at 74% 20%, hsla(45, 42%, 64%, 0.16) 0%, transparent 26%);
  }

  .hero-content {
    position: static;
    width: 100%;
    max-width: 1280px;
    padding: 9.75rem 6rem 5rem 8.5rem;
    display: grid;
    grid-template-columns: minmax(360px, 700px) minmax(280px, 390px);
    align-items: center;
    gap: 4.5rem;
  }

  .hero-copy-main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 1.15rem;
    max-width: 42rem;
    padding-top: 0;
    transform: translateY(0);
  }

  .hero-copy-side {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-end;
    align-self: stretch;
    min-height: 22rem;
    padding-top: 0;
  }

  .hero-kicker {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: hsl(45, 65%, 66%);
  }

  .hero-title {
    margin: 0;
    font-family: 'IBM Plex Serif', serif;
    font-size: clamp(3.4rem, 6vw, 6.1rem);
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: -0.06em;
    color: hsl(0, 0%, 98%);
    max-width: 10ch;
    text-wrap: balance;
    text-shadow:
      0 8px 28px hsla(214, 40%, 4%, 0.35),
      0 18px 60px hsla(214, 40%, 4%, 0.3);
  }

  .hero-description-shell {
    align-self: flex-end;
    margin-top: auto;
    margin-bottom: 0;
    padding: 1.15rem 1.2rem 1.2rem;
    border-radius: 20px;
    background:
      linear-gradient(180deg, hsla(214, 26%, 11%, 0.24) 0%, hsla(214, 22%, 9%, 0.18) 100%);
    border: 1px solid hsla(0, 0%, 100%, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      inset 0 1px 0 hsla(0, 0%, 100%, 0.05),
      0 18px 40px hsla(214, 40%, 4%, 0.12);
  }

  .hero-description {
    margin: 0;
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    letter-spacing: 0.015em;
    color: hsla(42, 30%, 94%, 0.92);
    max-width: 30ch;
  }

  .companies-section {
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .section-shell {
    width: 100%;
    max-width: 1400px;
    padding: 6rem 6rem 6.5rem;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.76rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(45, 52%, 46%);
  }

  .section-side-kicker {
    position: absolute;
    left: 32px;
    top: 50%;
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 4px;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: translateY(-50%) rotate(180deg);
    z-index: 2;
  }

  .section-side-kicker-light {
    color: hsla(0, 0%, 100%, 0.72);
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(320px, 720px) minmax(240px, 340px);
    gap: 3rem;
    align-items: end;
  }

  .section-copy {
    max-width: 760px;
  }

  .section-title {
    margin: 0;
    font-family: 'IBM Plex Serif', serif;
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.05em;
    color: hsl(214, 38%, 14%);
    max-width: 13ch;
    text-wrap: balance;
  }

  .large-title {
    max-width: 12ch;
    margin-bottom: 2.5rem;
  }

  .section-text {
    margin: 1.4rem 0 0;
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    letter-spacing: 0.015em;
    color: hsl(214, 20%, 30%);
    max-width: 50ch;
  }

  .section-intro {
    background:
      radial-gradient(circle at 85% 18%, hsla(45, 60%, 75%, 0.2) 0%, transparent 22%),
      linear-gradient(180deg, hsl(45, 35%, 98%) 0%, hsl(214, 26%, 97%) 100%);
  }

  .section-intro .section-grid {
    grid-template-columns: minmax(320px, 600px) minmax(420px, 560px);
    gap: 3.5rem;
    align-items: center;
    width: 100%;
  }

  .section-intro .section-copy {
    align-self: center;
  }

  .section-intro .section-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: clamp(7rem, 8vw, 8.5rem);
    position: static;
  }

  .section-intro-kicker {
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    color: hsl(45, 52%, 46%);
  }

  .section-intro .section-grid {
    transform: translateY(1rem);
  }

  .section-steps {
    --floating-nav-offset: 5.75rem;
    min-height: 100vh;
    background:
      radial-gradient(circle at 50% 48%, hsla(210, 54%, 78%, 0.22) 0%, hsla(210, 54%, 78%, 0.12) 18%, transparent 42%),
      radial-gradient(circle at 50% 52%, hsla(42, 62%, 72%, 0.16) 0%, transparent 28%),
      radial-gradient(circle at 18% 18%, hsla(206, 48%, 66%, 0.08) 0%, transparent 22%),
      radial-gradient(circle at 84% 24%, hsla(43, 46%, 62%, 0.08) 0%, transparent 18%),
      linear-gradient(180deg, hsl(42, 28%, 98%) 0%, hsl(40, 22%, 95%) 100%);
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .section-steps::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 50%, hsla(0, 0%, 100%, 0.28) 0%, transparent 36%),
      radial-gradient(circle at 50% 58%, hsla(214, 36%, 18%, 0.06) 0%, transparent 58%);
    pointer-events: none;
  }

  .section-steps::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, hsla(40, 26%, 94%, 0.88) 0%, transparent 16%, transparent 84%, hsla(40, 26%, 94%, 0.88) 100%),
      linear-gradient(180deg, hsla(42, 24%, 96%, 0.32) 0%, transparent 18%, transparent 82%, hsla(40, 22%, 94%, 0.42) 100%);
    pointer-events: none;
  }

  .section-steps .section-shell {
    max-width: 1320px;
    width: 100%;
    padding-top: 5rem;
    padding-bottom: 5.4rem;
    transform: translateY(calc(var(--floating-nav-offset) / 2));
    position: relative;
    z-index: 1;
  }

  .steps-shell {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: calc(100vh - var(--floating-nav-offset));
  }

  .steps-layout {
    display: grid;
    align-items: center;
    width: min(100%, 68rem);
    margin-inline: auto;
  }

  .steps-grid {
    display: grid;
    width: min(100%, 62rem);
    grid-template-columns: repeat(3, minmax(0, 18rem));
    justify-content: center;
    justify-items: center;
    column-gap: 1.75rem;
    row-gap: 1.75rem;
    align-items: stretch;
    margin-inline: auto;
  }

  .step-card {
    box-sizing: border-box;
    min-height: 24rem;
    padding: 1.75rem 1.5rem 1.6rem;
    border-radius: 28px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background:
      linear-gradient(180deg, hsl(213, 42%, 28%) 0%, hsl(216, 46%, 20%) 52%, hsl(219, 48%, 16%) 100%);
    border: 1px solid hsla(210, 38%, 88%, 0.08);
    box-shadow:
      0 26px 42px hsla(214, 30%, 12%, 0.18),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.08);
    z-index: 0;
    width: 100%;
    max-width: 18rem;
    margin: 0;
    align-items: center;
    text-align: center;
    justify-content: space-between;
    transition:
      box-shadow 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, hsla(0, 0%, 100%, 0.14) 0%, transparent 30%),
      linear-gradient(180deg, hsla(210, 64%, 76%, 0.12) 0%, transparent 44%),
      linear-gradient(180deg, transparent 0%, hsla(222, 52%, 10%, 0.12) 100%);
    pointer-events: none;
  }

  .step-card::after {
    content: '';
    position: absolute;
    inset: 0.7rem;
    border-radius: 20px;
    border: 1px solid hsla(211, 50%, 21%, 0.5);
    box-shadow:
      inset 0 1px 0 hsla(210, 58%, 38%, 0.18),
      inset 1px 0 0 hsla(210, 48%, 32%, 0.1),
      inset 0 -1px 0 hsla(217, 44%, 10%, 0.28),
      inset -1px 0 0 hsla(217, 44%, 10%, 0.18),
      0 1px 2px hsla(214, 42%, 8%, 0.08),
      0 0 0 1px hsla(216, 52%, 10%, 0.08);
    background: linear-gradient(
      180deg,
      hsla(212, 44%, 26%, 0.06) 0%,
      hsla(214, 42%, 20%, 0.025) 38%,
      hsla(217, 46%, 12%, 0.05) 100%
    );
    pointer-events: none;
    transition:
      border-color 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card:hover {
    border-color: hsla(210, 42%, 90%, 0.1);
    box-shadow:
      0 28px 48px hsla(214, 32%, 10%, 0.2),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.09);
    background:
      linear-gradient(180deg, hsl(212, 44%, 31%) 0%, hsl(216, 46%, 22%) 52%, hsl(219, 48%, 17%) 100%);
  }

  .step-card:hover::after {
    border-color: hsla(211, 52%, 23%, 0.58);
