---
import BaseLayout from '../layouts/Base.astro';
import FloatingNavbar from '../components/navbar/FloatingNavbar.svelte';
import SectionStacking from '../components/SectionStacking.svelte';
import Footer from '../components/Footer.svelte';
import BackToTop from '../components/BackToTop.astro';
import IntroQaRotator from '../components/for-you/IntroQaRotator.svelte';
import CriteriaRevealSection from '../components/for-you/CriteriaRevealSection.svelte';
import { kloutForYouSchema } from '../lib/schema';

const qaCases = [
  {
    eyebrow: 'Caso 01',
    question:
      'Pago caro pelo meu plano e não tenho acesso ao novo Hospital São Luiz Alphaville, que é excelente e perto de casa. O que dá pra fazer?',
    answer:
      'Buscamos opções com acesso mais útil para sua rotina. Em vez de boa cobertura no papel, priorizamos rede mais prática e conveniente.',
    cta: 'Analisar acesso hospitalar',
    href: '/analise',
  },
  {
    eyebrow: 'Caso 02',
    question:
      'Meu médico saiu da rede e estou pagando consulta por fora. É possível rever o plano?',
    answer:
      'Sim. Lemos a apólice e avaliamos alternativas que podem aproximar seu contrato de nomes mais relevantes para sua rotina.',
    cta: 'Rever rede credenciada',
    href: '/analise',
  },
  {
    eyebrow: 'Caso 03',
    question:
      'Hoje pago por coberturas que não fazem mais sentido para minha família',
    answer:
      'Seu plano precisa acompanhar casamento, filhos, idade e nova rotina. A recomendação certa pode significar sair de excesso genérico e entrar em acesso mais coerente.',
    cta: 'Revisar a apólice',
    href: '/analise',
  },
];
---

<BaseLayout
  title="Para Você | Klout"
  description="Encontre um plano de saúde alinhado à sua rotina, rede de atendimento, cobertura e orçamento com a curadoria técnica da Klout."
  criticalImage="/images/einstein_01-1280.avif"
  criticalImageSrcset="/images/einstein_01-768.avif 768w, /images/einstein_01-1280.avif 1280w, /images/einstein_01-1920.avif 1920w"
  criticalImageSizes="100vw"
  criticalImageType="image/avif"
  structuredData={kloutForYouSchema}
>
  <FloatingNavbar client:media="(min-width: 769px)" />
  <SectionStacking client:media="(min-width: 769px)" />

  <main id="main-content">
    <section id="voce" class="for-you-hero" data-stack-section data-dark-section>
      <div class="hero-media">
        <picture class="hero-picture">
          <source
            type="image/avif"
            media="(max-width: 768px)"
            srcset="/images/einstein_01-768.avif 768w, /images/einstein_01-1280.avif 1280w"
            sizes="100vw"
          />
          <source
            type="image/webp"
            media="(max-width: 768px)"
            srcset="/images/einstein_01-768.webp 768w, /images/einstein_01-1280.webp 1280w"
            sizes="100vw"
          />
          <source
            type="image/avif"
            srcset="/images/einstein_01-1440.avif 1440w, /images/einstein_01-1600.avif 1600w, /images/einstein_01-1920.avif 1920w"
            sizes="100vw"
          />
          <source
            type="image/webp"
            srcset="/images/einstein_01-1280.webp 1280w, /images/einstein_01-1920.webp 1920w, /images/einstein_01-2160.webp 2160w"
            sizes="100vw"
          />
          <img
            src="/images/einstein_01-1920.webp"
            alt="Pessoa em atendimento consultivo com foco em decisões de plano de saúde"
            class="hero-image"
            loading="eager"
            fetchpriority="high"
            width="1920"
            height="1279"
          />
        </picture>
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <div class="hero-copy-main">
          <h1 class="hero-title">Consultoria individual para decisões mais seguras em planos de saúde.</h1>
        </div>

        <div class="hero-copy-side">
          <div class="hero-description-shell">
            <p class="hero-description">
                Seu plano precisa combinar com a vida que você leva, com os hospitais que você prioriza e laboratórios que realmente facilitam a sua rotina.
            </p>
          </div>
          <p class="hero-caption">Einstein Morumbi | São Paulo</p>
        </div>
      </div>
    </section>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        if (root.classList.contains('for-you-hero-entry-complete')) return;
        window.setTimeout(() => {
          root.classList.add('for-you-hero-entry-complete');
        }, 2400);
      })();
    </script>

    <section class="for-you-section section-intro" data-stack-section>
      <div class="section-intro-kicker section-side-kicker">Leitura individual</div>
      <div class="section-shell">
        <div class="section-grid">
          <div class="section-copy">
            <h2 class="section-title">A recomendação certa depende do seu contexto</h2>
            <p class="section-text">
              Em vez de comparar planos de forma superficial, avaliamos o que faz sentido para o seu contexto: rotina, idade, histórico, prioridades médicas, previsibilidade financeira e margem de segurança para o futuro.
            </p>
          </div>
          <IntroQaRotator client:visible items={qaCases} />
        </div>
      </div>
    </section>

    <section class="for-you-section section-steps" data-stack-section data-stack-end="300%" data-dark-section>
      <p class="eyebrow section-side-kicker">Como funciona</p>
      <div class="section-shell steps-shell">
        <div class="steps-intro">
          <h2 class="section-title large-title">Um processo direto, técnico e orientado pela sua realidade.</h2>
          <p class="section-text steps-intro-text">
            A leitura começa no seu contexto e termina em uma recomendação aderente àquilo que você precisa e deseja.
          </p>
        </div>

        <div class="steps-grid">
          <article class="step-card step-card-primary">
            <div class="step-meta">
              <span class="step-index">01</span>
              <p class="step-kicker">Diagnóstico inicial</p>
            </div>
            <h3 class="step-title">Sua rotina</h3>
            <p class="step-text">Entendemos quem usa o plano, quais hospitais e laboratórios importam, quanto você paga hoje e quais são as suas prioridades.</p>
          </article>

          <article class="step-card step-card-secondary">
            <div class="step-meta">
              <span class="step-index">02</span>
              <p class="step-kicker">Leitura técnica</p>
            </div>
            <h3 class="step-title">Visão crítica das opções</h3>
            <p class="step-text">Verificamos quais hospitais, laboratórios e médicos entram na rede, o que o plano cobre, quais carências ainda existem e possíveis limitações no uso.</p>
          </article>

          <article class="step-card step-card-accent">
            <div class="step-meta">
              <span class="step-index">03</span>
              <p class="step-kicker">Direção final</p>
            </div>
            <h3 class="step-title">Recomendação estratégica</h3>
            <p class="step-text">Indicamos se vale manter, ajustar ou trocar. Mudanças só são consideradas quando oferecem vantagens reais.</p>
          </article>
        </div>
      </div>
    </section>

    <CriteriaRevealSection client:visible />

    <section class="for-you-section section-cta" data-dark-section>
      <p class="eyebrow section-side-kicker section-side-kicker-light">Próximo passo</p>
      <div class="section-shell cta-shell">
        <div class="cta-box">
          <h2 class="section-title cta-title">Se a decisão é importante, vale ser bem assessorada.</h2>
          <p class="section-text cta-text">
            Inicie a análise do seu caso e receba uma orientação mais segura sobre qual plano faz sentido para você.
          </p>
          <a href="/analise" class="for-you-button">
            Iniciar análise
            <svg class="for-you-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BackToTop />
</BaseLayout>

<style>
  .for-you-hero {
    position: relative;
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    background: hsl(214, 18%, 10%);
  }

  .hero-media,
  .hero-picture,
  .hero-image,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-media {
    background: hsl(214, 18%, 10%);
  }

  .hero-picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 24%;
    filter: saturate(0.94) contrast(1.02) brightness(0.88);
    transform-origin: center;
  }

  .hero-overlay {
    background:
      linear-gradient(180deg, hsla(214, 30%, 8%, 0.08) 0%, hsla(214, 30%, 8%, 0.18) 30%, hsla(214, 30%, 8%, 0.68) 100%),
      linear-gradient(90deg, hsla(214, 35%, 8%, 0.72) 0%, hsla(214, 35%, 8%, 0.3) 42%, hsla(214, 35%, 8%, 0.14) 100%),
      radial-gradient(circle at 72% 18%, hsla(45, 60%, 65%, 0.12) 0%, transparent 26%);
  }

  .hero-content {
    position: static;
    width: 100%;
    max-width: 1280px;
    padding: 10rem 6rem 4.5rem 8.5rem;
    display: grid;
    grid-template-columns: minmax(320px, 760px) minmax(220px, 360px);
    align-items: end;
    gap: 3.5rem;
  }

  .hero-copy-main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    transform: translateY(-2rem);
  }

  .hero-copy-side {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-self: stretch;
    min-height: 26rem;
  }

  .hero-kicker {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: hsl(45, 65%, 66%);
  }

  .hero-title {
    margin: 0;
    font-family: 'IBM Plex Serif', serif;
    font-size: clamp(3.4rem, 6.2vw, 6.2rem);
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: -0.06em;
    color: hsl(0, 0%, 98%);
    max-width: 10ch;
    text-wrap: balance;
    text-shadow:
      0 8px 28px hsla(214, 40%, 4%, 0.35),
      0 18px 60px hsla(214, 40%, 4%, 0.3);
  }

  .hero-description-shell {
    align-self: flex-end;
    margin-top: auto;
    margin-bottom: auto;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: hsla(214, 24%, 10%, 0.14);
    border: 1px solid hsla(0, 0%, 100%, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      inset 0 1px 0 hsla(0, 0%, 100%, 0.05),
      0 10px 30px hsla(214, 40%, 4%, 0.08);
    transform: none;
  }

  .hero-description {
    margin: 0;
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    letter-spacing: 0.015em;
    color: hsla(42, 30%, 94%, 0.92);
    max-width: 30ch;
  }

  .hero-caption {
    margin: 0;
    margin-top: auto;
    margin-bottom: 0;
    padding-top: 0;
    transform: none;
    align-self: flex-end;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsla(0, 0%, 100%, 0.54);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-image {
      animation: for-you-hero-image-enter 2200ms cubic-bezier(0.22, 1, 0.36, 1) both;
      will-change: transform;
    }

    .hero-overlay {
      animation: for-you-hero-overlay-enter 1800ms ease-out 180ms both;
    }

    .hero-description-shell {
      animation: for-you-hero-copy-enter 820ms cubic-bezier(0.22, 1, 0.36, 1) 260ms both;
    }

    .hero-caption {
      animation: for-you-hero-copy-enter 760ms cubic-bezier(0.22, 1, 0.36, 1) 420ms both;
    }
  }

  :global(html.for-you-hero-entry-complete) .hero-image,
  :global(html.for-you-hero-entry-complete) .hero-overlay,
  :global(html.for-you-hero-entry-complete) .hero-title,
  :global(html.for-you-hero-entry-complete) .hero-description-shell,
  :global(html.for-you-hero-entry-complete) .hero-caption {
    animation: none;
  }

  :global(html.for-you-hero-entry-complete) .hero-image {
    transform: scale(1);
    will-change: auto;
  }

  :global(html.for-you-hero-entry-complete) .hero-overlay,
  :global(html.for-you-hero-entry-complete) .hero-title,
  :global(html.for-you-hero-entry-complete) .hero-description-shell,
  :global(html.for-you-hero-entry-complete) .hero-caption {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @keyframes for-you-hero-image-enter {
    from {
      transform: scale(1.1);
    }

    to {
      transform: scale(1);
    }
  }

  @keyframes for-you-hero-overlay-enter {
    from {
      opacity: 0.18;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes for-you-hero-copy-enter {
    from {
      opacity: 0;
      transform: translate3d(0, 2.625rem, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .for-you-section {
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .section-shell {
    width: 100%;
    max-width: 1400px;
    padding: 6rem 6rem 6.5rem;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.76rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(45, 52%, 46%);
  }

  .section-side-kicker {
    position: absolute;
    left: 32px;
    top: 50%;
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 4px;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: translateY(-50%) rotate(180deg);
    z-index: 2;
  }

  .section-side-kicker-light {
    color: hsla(0, 0%, 100%, 0.72);
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(320px, 720px) minmax(240px, 340px);
    gap: 3rem;
    align-items: end;
  }

  .section-copy {
    max-width: 760px;
  }

  .section-title {
    margin: 0;
    font-family: 'IBM Plex Serif', serif;
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.05em;
    color: hsl(214, 38%, 14%);
    max-width: 13ch;
    text-wrap: balance;
  }

  .large-title {
    max-width: 12ch;
    margin-bottom: 2.5rem;
  }

  .section-text {
    margin: 1.4rem 0 0;
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    letter-spacing: 0.015em;
    color: hsl(214, 20%, 30%);
    max-width: 50ch;
  }

  .section-intro {
    background:
      radial-gradient(circle at 85% 18%, hsla(45, 60%, 75%, 0.2) 0%, transparent 22%),
      linear-gradient(180deg, hsl(45, 35%, 98%) 0%, hsl(214, 26%, 97%) 100%);
  }

  .section-intro .section-grid {
    grid-template-columns: minmax(320px, 600px) minmax(420px, 560px);
    gap: 3.5rem;
    align-items: center;
    width: 100%;
  }

  .section-intro .section-copy {
    align-self: center;
  }

  .section-intro .section-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: clamp(7rem, 8vw, 8.5rem);
    position: static;
  }

  .section-intro-kicker {
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(45, 52%, 46%);
  }

  .section-intro .section-grid {
    transform: translateY(1rem);
  }

  .section-steps {
    --floating-nav-offset: 6.75rem;
    min-height: 100vh;
    background:
      radial-gradient(circle at 16% 22%, hsla(43, 72%, 62%, 0.24) 0%, transparent 24%),
      radial-gradient(circle at 84% 78%, hsla(195, 64%, 54%, 0.22) 0%, transparent 28%),
      linear-gradient(180deg, hsl(214, 42%, 17%) 0%, hsl(208, 46%, 12%) 52%, hsl(204, 42%, 10%) 100%);
    align-items: center;
  }

  .section-steps .section-shell {
    max-width: 1320px;
    width: 100%;
    padding-top: 4.25rem;
    padding-bottom: 4.5rem;
    transform: translateY(calc(var(--floating-nav-offset) / 2));
  }

  .steps-shell {
    display: grid;
    grid-template-columns: minmax(280px, 420px) minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
    width: 100%;
  }

  .steps-intro {
    position: relative;
    padding: 2rem 2rem 2.2rem;
    border-radius: 30px;
    background:
      linear-gradient(180deg, hsla(212, 30%, 18%, 0.92) 0%, hsla(210, 34%, 14%, 0.86) 100%);
    border: 1px solid hsla(0, 0%, 100%, 0.08);
    box-shadow:
      0 24px 50px hsla(214, 44%, 4%, 0.28),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .section-steps > .section-side-kicker {
    color: hsl(43, 70%, 66%);
  }

  .steps-intro .section-title {
    color: hsl(0, 0%, 98%);
  }

  .steps-intro-text {
    color: hsla(0, 0%, 100%, 0.76);
    max-width: 34ch;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: minmax(320px, 560px);
    justify-content: end;
    gap: 1.15rem;
    align-items: start;
    position: relative;
    padding-left: 2rem;
  }

  .steps-grid::before {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 1px;
    background: linear-gradient(180deg, hsla(43, 72%, 64%, 0.52) 0%, hsla(194, 68%, 64%, 0.18) 100%);
    pointer-events: none;
  }

  .step-card {
    min-height: 6.65rem;
    padding: 1.45rem 1.3rem 1.5rem;
    border-radius: 26px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background:
      linear-gradient(160deg, hsl(41, 48%, 92%) 0%, hsl(43, 42%, 84%) 100%);
    border: 1px solid hsla(40, 38%, 34%, 0.14);
    box-shadow:
      0 20px 36px hsla(214, 34%, 4%, 0.18),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.08);
    z-index: 1;
    width: 100%;
  }

  .step-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, hsla(0, 0%, 100%, 0.14) 0%, transparent 34%),
      linear-gradient(180deg, hsla(0, 0%, 100%, 0.06) 0%, transparent 58%);
    pointer-events: none;
  }

  .step-index {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    color: hsla(45, 78%, 72%, 0.92);
    position: relative;
    z-index: 1;
  }

  .step-meta {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 0.48rem;
    position: relative;
    z-index: 1;
    flex-wrap: wrap;
  }

  .step-index,
  .step-kicker {
    color: hsl(212, 34%, 30%);
  }

  .step-title {
    color: hsl(214, 42%, 16%);
  }

  .step-text {
    color: hsl(214, 18%, 28%);
  }

  .step-kicker {
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  .step-title {
    margin: 0 0 0.5rem;
    font-family: 'IBM Plex Serif', serif;
    font-size: 1.06rem;
    font-weight: 400;
    line-height: 1.14;
    position: relative;
    z-index: 1;
  }

  .step-text {
    margin: 0;
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.79rem;
    line-height: 1.58;
    letter-spacing: 0.015em;
    position: relative;
    z-index: 1;
  }

  .section-criteria {
    min-height: auto;
    background:
      radial-gradient(circle at 18% 30%, hsla(45, 55%, 76%, 0.12) 0%, transparent 24%),
      linear-gradient(180deg, hsl(45, 34%, 98%) 0%, hsl(45, 30%, 96%) 100%);
    align-items: flex-start;
    overflow: visible;
  }

  .criteria-shell {
    display: block;
    padding-top: 5rem;
    padding-bottom: 7rem;
  }

  .criteria-panel {
    position: relative;
    min-width: 0;
  }

  .criteria-intro-text {
    max-width: 31ch;
    margin-top: 0;
  }

  .criteria-figure {
    margin: 0;
    position: relative;
    min-height: 44rem;
    border-radius: 34px;
    overflow: hidden;
    background: hsla(0, 0%, 100%, 0.74);
    border: 1px solid hsla(214, 24%, 32%, 0.08);
    box-shadow:
      0 34px 72px hsla(214, 24%, 18%, 0.14),
      0 10px 24px hsla(214, 24%, 18%, 0.08);
  }

  .criteria-figure::after {
    content: '';
    position: absolute;
    inset: 0;
