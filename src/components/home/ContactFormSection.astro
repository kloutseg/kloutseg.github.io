---
import SectionIndicator from './SectionIndicators.svelte';
---

<section id="contato" data-stack-section>
  <SectionIndicator number="06" title="Contato" />

  <div class="content-wrapper">
    <div class="form-layout">
      <div class="form-text-content">
        <h2 class="form-headline">
          Inicie a análise do seu caso
        </h2>
        <p class="form-subheadline">
         Respondemos em até 24 horas úteis para entender o seu cenário e definir o próximo passo.
        </p>
        <div class="divider-wrapper">
          <div class="divider-line"></div>
        </div>

        <a href="/analise" class="gold-cta-button">
          Iniciar análise
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="visual-card-wrapper">
        <figure class="contact-visual" aria-label="Atendimento consultivo">
          <div class="visual-stage">
            <div class="visual-capsule">
              <img
                src="/images/contacting_01.webp"
                alt="Mulher consultando o celular em ambiente iluminado"
                class="visual-image"
                loading="lazy"
              />
              <div class="visual-overlay"></div>
              <div class="visual-shine"></div>
            </div>
          </div>
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    min-height: 100vh;
    width: 100vw;
    max-width: 100%;
    position: relative;
    margin: 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4.5rem 7rem 7rem 5.5rem;
    overflow: visible;
    z-index: 20;
    scroll-behavior: smooth;
    background: linear-gradient(
      180deg,
      hsl(42, 24%, 98%) 0%,
      hsl(42, 18%, 97%) 48%,
      hsl(214, 18%, 96%) 100%
    );
  }

  section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, hsla(45, 30%, 90%, 0.4) 0%, transparent 35%),
      radial-gradient(circle at 80% 70%, hsla(214, 20%, 92%, 0.3) 0%, transparent 35%),
      radial-gradient(circle at 50% 50%, hsla(45, 25%, 95%, 0.2) 0%, transparent 50%);
    pointer-events: none;
  }

  .content-wrapper {
    width: 100%;
    max-width: 1320px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .form-layout {
    display: grid;
    grid-template-columns: minmax(340px, 0.9fr) minmax(420px, 1.05fr);
    gap: 5rem;
    align-items: start;
  }

  .form-text-content {
    display: flex;
    flex-direction: column;
    gap: clamp(0.95rem, 1.5vw, 1.35rem);
    justify-content: center;
    min-height: 40rem;
    padding-top: 0;
    align-items: flex-start;
  }

  .form-headline {
    font-family: 'IBM Plex Serif', serif;
    font-weight: 400;
    font-size: 1.7rem;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 0;
    color: hsl(214, 40%, 15%);
    text-shadow:
      0 1px 2px hsla(214, 40%, 15%, 0.06),
      0 4px 24px hsla(214, 40%, 15%, 0.04),
      0 8px 48px hsla(214, 40%, 15%, 0.02);
  }

  @media (min-width: 769px) {
    .form-headline {
      font-size: clamp(4rem, 7vw, 6.1rem);
      line-height: 0.94;
      letter-spacing: -0.065em;
      max-width: 9ch;
      text-wrap: balance;
      text-shadow: 0 8px 28px hsla(214, 40%, 15%, 0.04);
    }
  }

  .form-subheadline {
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.98rem;
    font-weight: 400;
    line-height: 1.82;
    color: hsl(214, 18%, 29%);
    margin: 0;
    max-width: 480px;
    letter-spacing: 0.01em;
    opacity: 0.9;
  }

  .divider-wrapper {
    display: flex;
    margin-top: 0.35rem;
  }

  .divider-line {
    width: 7rem;
    height: 2px;
    background: linear-gradient(
      90deg,
      hsla(42, 30%, 54%, 0.82) 0%,
      hsla(42, 26%, 46%, 0.64) 50%,
      hsla(42, 22%, 40%, 0.28) 100%
    );
    border-radius: 2px;
    box-shadow: none;
  }

  .gold-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 11px 18px;
    border-radius: 16px;
    font-family: 'Proxima Nova', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1), background 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin-top: 0.8rem;
    width: fit-content;
    align-self: flex-start;
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      hsl(42, 34%, 42%) 0%,
      hsl(42, 30%, 36%) 52%,
      hsl(40, 28%, 30%) 100%
    );
    color: hsl(0, 0%, 100%);
    box-shadow:
      0 10px 22px hsla(42, 28%, 14%, 0.2),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.15);
  }

  .gold-cta-button:hover {
    transform: translateY(-3px);
    box-shadow:
      0 18px 34px hsla(42, 28%, 14%, 0.28),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.15);
  }

  .gold-cta-button:active {
    transform: translateY(0) scale(0.98);
  }

  .gold-cta-button:focus-visible {
    outline: 2px solid hsla(42, 75%, 32%, 0.85);
    outline-offset: 4px;
  }

  .gold-cta-button svg {
    width: 18px;
    height: 18px;
    position: relative;
    z-index: 1;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gold-cta-button:hover svg {
    transform: translateX(5px);
  }

  .visual-card-wrapper {
    perspective: 1400px;
    min-height: 40rem;
    display: flex;
    align-items: stretch;
    padding-top: 0.5rem;
  }

  .contact-visual {
    width: 100%;
    margin: 0;
  }

  .visual-stage {
    min-height: 40rem;
    display: flex;
    justify-content: center;
    align-items: stretch;
    padding: 0.5rem 0;
  }

  .visual-capsule {
    position: relative;
    width: min(100%, 28rem);
    min-height: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: hsl(40, 20%, 88%);
    box-shadow:
      0 18px 40px hsla(214, 28%, 16%, 0.12),
      0 36px 94px hsla(214, 28%, 16%, 0.1),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.55);
    transition:
      width 0.75s cubic-bezier(0.22, 1, 0.36, 1),
      border-radius 0.75s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    isolation: isolate;
  }

  .visual-capsule::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid hsla(0, 0%, 100%, 0.28);
    pointer-events: none;
    z-index: 2;
  }

  .visual-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% center;
    filter: none;
    transform: none;
  }

  .visual-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, hsla(40, 22%, 92%, 0.02) 0%, transparent 22%, transparent 72%, hsla(214, 24%, 10%, 0.18) 100%),
      linear-gradient(110deg, hsla(42, 32%, 78%, 0.1) 0%, transparent 38%, transparent 100%);
    z-index: 1;
    pointer-events: none;
  }

  .visual-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, hsla(0, 0%, 100%, 0.36) 0%, hsla(0, 0%, 100%, 0.06) 18%, transparent 34%);
    opacity: 0.42;
    mix-blend-mode: screen;
    z-index: 1;
    pointer-events: none;
    transition: opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (max-width: 1200px) {
    section {
      padding: 4.5rem 6rem 6rem 5rem;
    }

    .form-layout {
      gap: 4.5rem;
    }

    .form-text-content {
      min-height: 38rem;
      padding-top: 0;
    }

    .visual-card-wrapper,
    .visual-stage {
      min-height: 38rem;
    }
  }

  @media (max-width: 992px) {
    section {
      padding: 4.5rem 3rem 5.5rem 3rem;
    }

    .form-layout {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      align-items: center;
    }

    .form-text-content {
      min-height: auto;
      text-align: center;
      align-items: center;
      padding-top: 0;
    }

    .form-subheadline {
      max-width: 100%;
    }

    .divider-wrapper {
      justify-content: center;
    }

    .visual-card-wrapper,
    .visual-stage {
      min-height: 35rem;
    }

    .visual-card-wrapper {
      padding-top: 0;
    }

    .visual-capsule {
      width: min(100%, 30rem);
      border-radius: 1.5rem;
    }

    .visual-image {
      object-position: 58% center;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 4rem 2rem 5.5rem 2rem;
      justify-content: center;
      align-items: center;
      padding-top: 6.5rem;
    }

    .content-wrapper {
      max-width: 100%;
      padding: 0;
    }

    .form-layout {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 520px;
      margin: 0 auto;
    }

    .form-text-content {
      order: 2;
      padding-top: 0;
      max-width: 520px;
      text-align: center;
      align-items: center;
    }

    .form-headline {
      font-size: 1.5rem;
    }

    .form-subheadline {
      font-size: 0.85rem;
      max-width: 100%;
    }

    .divider-wrapper {
      justify-content: center;
    }

    .gold-cta-button {
      width: auto;
      max-width: none;
      min-height: 48px;
      padding: 0.85rem 1.4rem;
      border: 1px solid hsla(42, 30%, 52%, 0.26);
      border-radius: 16px;
      box-sizing: border-box;
      font-size: 0.82rem;
      margin-top: 1rem;
      align-self: center;
      box-shadow:
        0 10px 22px hsla(42, 28%, 14%, 0.2),
        inset 0 1px 0 hsla(0, 0%, 100%, 0.12);
    }

    .visual-card-wrapper,
    .visual-stage {
      width: 100%;
      min-height: auto;
    }

    .visual-card-wrapper {
      order: 1;
      perspective: none;
    }

    .contact-visual {
      width: 100%;
    }

    .visual-capsule {
      width: 100%;
      max-width: 520px;
      min-height: auto;
      aspect-ratio: 16 / 10;
      border-radius: 16px;
    }

    .visual-image {
      object-position: 62% 50%;
    }
  }

  @media (max-width: 480px) {
    section {
      padding: 3.5rem 1.5rem 4.5rem 1.5rem;
    }

    .visual-card-wrapper,
    .visual-stage {
      min-height: auto;
    }

    .visual-capsule {
      aspect-ratio: 16 / 11;
      border-radius: 16px;
    }

    .visual-image {
      object-position: 64% 50%;
    }
  }
</style>
