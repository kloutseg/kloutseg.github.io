    font: 500 .62rem/1 'IBM Plex Mono', monospace;
    letter-spacing: .12em;
  }

  .reading-dialog-close {
    width: 3rem;
    height: 3rem;
    padding: 0;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    touch-action: manipulation;
  }

  .reading-dialog-close svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .reading-dialog-content {
    display: grid;
    grid-template-columns: 2.65rem minmax(0, 1fr) 2.65rem;
    align-items: center;
    margin-inline: -.35rem;
  }

  .reading-dialog-copy {
    min-width: 0;
