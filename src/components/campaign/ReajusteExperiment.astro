  .reading-dialog-nav:hover,
  .reading-dialog-nav:focus-visible {
    opacity: 1;
  }

  .reading-dialog-nav:active {
    transform: scale(.92);
  }

  .reading-dialog-close:focus-visible,
  .reading-dialog-nav:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 3px;
  }

  :global(html[data-reajuste-variant="sensorial"]) .reading-dialog-panel {
    box-shadow: 0 -24px 70px hsla(29, 30%, 12%, .22);
  }

  @keyframes reading-dialog-panel-in {
    from {
      opacity: .35;
      transform: translate3d(0, 1.25rem, 0);
