    font: 400 clamp(2.45rem, 3.7vw, 3.75rem)/1.04 'IBM Plex Serif', serif;
    letter-spacing: -.042em;
    text-wrap: balance;
  }

  .mechanism-intro p {
    width: min(100%, 58ch);
    margin: 0;
    color: var(--muted);
    font: 400 1rem/1.72 'Proxima Nova', sans-serif;
  }

  .mechanism-portrait {
    position: absolute;
    top: calc(var(--mechanism-photo-lift) * -1);
    right: 0;
    bottom: auto;
    z-index: 2;
    width: min(38%, 34rem);
    height: clamp(52rem, 73vw, 65.5rem);
    pointer-events: none;
    min-height: 0;
    display: block;
    overflow: hidden;
    border: 0;
    background: transparent;
    box-shadow: 0 34px 82px hsla(213, 36%, 10%, .15);
  }

  .mechanism-portrait img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 54%;
  }

  :global(html[data-reajuste-variant="sensorial"]) .mechanism-portrait {
    border-radius: 28px;
    box-shadow: 0 28px 70px hsla(29, 30%, 18%, .14);
  }

  .mechanism-effects {
    grid-column: 1;
    grid-row: 2;
    min-width: 0;
    align-self: start;
  }

  .mechanism-effects > h3 {
    margin: 0 0 1.5rem;
    font: 400 clamp(1.45rem, 2vw, 1.8rem)/1.15 'IBM Plex Serif', serif;
    letter-spacing: -.025em;
  }

  .effect-accordion {
    interpolate-size: allow-keywords;
  }

  .effect-accordion details {
    border-bottom: 1px solid var(--line);
  }

  .effect-accordion details::details-content {
    block-size: 0;
    overflow: clip;
    opacity: 0;
    transition:
      block-size 1.15s cubic-bezier(.65, 0, .35, 1),
      opacity 1.15s cubic-bezier(.65, 0, .35, 1),
      content-visibility 1.15s allow-discrete;
  }

  .effect-accordion details[open]::details-content {
    block-size: auto;
    opacity: 1;
  }

  @starting-style {
    .effect-accordion details[open]::details-content {
      block-size: 0;
      opacity: 0;
    }
  }

  .effect-accordion summary {
    min-height: 3.5rem;
    padding-block: .95rem;
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr) 1.4rem;
    gap: .75rem;
    align-items: center;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }

  .effect-accordion summary::-webkit-details-marker {
    display: none;
  }

  .effect-accordion summary::marker {
    content: "";
  }

  .effect-accordion summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .effect-accordion summary > span:nth-child(2) {
    font: 500 .92rem/1.38 'Proxima Nova', sans-serif;
  }

  .effect-index {
    color: var(--accent-strong);
    font: 500 .6rem/1 'IBM Plex Mono', monospace;
    letter-spacing: .1em;
  }

  .effect-toggle {
    position: relative;
    width: 1.1rem;
    height: 1.1rem;
    justify-self: end;
  }

  .effect-toggle::before,
  .effect-toggle::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: .8rem;
    height: 1px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition:
      opacity .85s cubic-bezier(.65, 0, .35, 1),
      transform .85s cubic-bezier(.65, 0, .35, 1);
  }

  .effect-toggle::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .effect-accordion details[open] .effect-toggle::after {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(0);
  }

  .effect-accordion details[open] summary > span:nth-child(2) {
    color: var(--accent-strong);
  }

  .effect-panel {
    transform: translate3d(0, -.35rem, 0);
    transition: transform 1.15s cubic-bezier(.65, 0, .35, 1);
  }

  .effect-accordion details[open] .effect-panel {
    transform: translate3d(0, 0, 0);
  }

  .effect-panel p {
    width: min(100%, 56ch);
    margin: 0;
    padding: 0 2.15rem 1.35rem 3rem;
    color: var(--muted);
    font: 400 .87rem/1.64 'Proxima Nova', sans-serif;
  }

  .reading-section {
    overflow: clip;
    background: var(--surface);
  }

  :global(html[data-reajuste-variant="sensorial"]) .reading-section {
    background:
      linear-gradient(180deg, var(--surface) 0%, hsl(38, 31%, 95%) 100%);
  }

  .reading-layout {
    display: grid;
    grid-template-columns: minmax(18rem, .62fr) minmax(34rem, 1.38fr);
    gap: clamp(4rem, 7vw, 7rem);
    align-items: center;
  }

  .reading-intro {
    position: static;
    display: grid;
    gap: 1.35rem;
  }

  .reading-intro h2 {
    max-width: 16ch;
    font-size: clamp(2.35rem, 3.2vw, 3.35rem);
    line-height: 1.03;
  }

  .reading-intro > p:last-child {
    max-width: 40ch;
    font-size: 1rem;
    line-height: 1.7;
  }

  .reading-visual {
    min-width: 0;
    display: grid;
    justify-items: center;
  }

  .reading-wheel {
    position: relative;
    width: min(100%, 43rem);
    aspect-ratio: 1;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: var(--surface);
    box-shadow: 0 28px 72px hsla(213, 30%, 12%, .08);
  }

  .reading-wheel::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 2;
    width: .7rem;
    height: .7rem;
    border: 3px solid var(--surface);
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 1px var(--line);
    transform: translate(-50%, -50%);
  }

  .reading-front {
    min-width: 0;
    padding: clamp(2.5rem, 4vw, 4rem) clamp(1.8rem, 3vw, 3rem);
    display: flex;
    flex-direction: column;
    background: var(--page);
  }

  .reading-front:nth-child(1) {
    align-items: flex-end;
    justify-content: flex-end;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    text-align: right;
  }

  .reading-front:nth-child(2) {
    align-items: flex-start;
    justify-content: flex-end;
    border-bottom: 1px solid var(--line);
    background: var(--surface-soft);
  }

  .reading-front:nth-child(3) {
    align-items: flex-end;
    justify-content: flex-start;
    border-right: 1px solid var(--line);
    background: var(--surface);
    text-align: right;
  }

  .reading-front:nth-child(4) {
    align-items: flex-start;
    justify-content: flex-start;
    background: var(--dark);
    color: white;
  }

  .reading-front > span {
    color: var(--accent-strong);
    font: 500 .58rem/1 'IBM Plex Mono', monospace;
    letter-spacing: .11em;
  }

  .reading-front:nth-child(4) > span {
    color: hsl(40, 42%, 68%);
  }

  .reading-front h3 {
    margin: .75rem 0 .6rem;
    font: 400 clamp(1.3rem, 1.9vw, 1.75rem)/1.08 'IBM Plex Serif', serif;
    letter-spacing: -.025em;
  }

  .reading-front p {
    max-width: 28ch;
    margin: 0;
    color: var(--muted);
    font: 400 clamp(.72rem, .85vw, .8rem)/1.5 'Proxima Nova', sans-serif;
  }

  .reading-front:nth-child(4) p {
    color: hsla(0, 0%, 100%, .68);
  }

  :global(html[data-reajuste-variant="sensorial"]) .reading-wheel {
    border-color: hsla(29, 22%, 34%, .15);
    box-shadow: 0 30px 76px hsla(29, 30%, 18%, .11);
  }

  :global(html[data-reajuste-variant="sensorial"]) .reading-front:nth-child(1) {
    background: hsl(39, 42%, 97%);
  }

  :global(html[data-reajuste-variant="sensorial"]) .reading-front:nth-child(2) {
    background: hsl(35, 30%, 92%);
  }

  :global(html[data-reajuste-variant="sensorial"]) .reading-front:nth-child(4) {
    background: hsl(169, 24%, 14%);
  }

  .reading-mobile-notes {
    display: none;
  }

  .reading-front {
    position: relative;
  }

  .reading-front-trigger,
  .reading-mobile-hint {
    display: none;
  }

  :global(html:has(.reading-dialog[open])),
  :global(body:has(.reading-dialog[open])) {
    overflow: hidden;
  }

  .reading-dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: none;
    height: 100%;
    max-height: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    border: 0;
    background: transparent;
    color: var(--ink);
  }

  .reading-dialog[open] {
    display: grid;
    align-items: end;
    justify-items: center;
  }

  .reading-dialog::backdrop {
    background: hsla(213, 48%, 5%, .58);
  }

  .reading-dialog-panel {
    width: min(100%, 32rem);
    max-height: min(82vh, 42rem);
    padding: 1rem 1.1rem max(1.25rem, env(safe-area-inset-bottom));
