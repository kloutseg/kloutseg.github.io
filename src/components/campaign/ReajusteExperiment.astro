---
import BaseLayout from '../../layouts/Base.astro';
import ReajusteLeadForm from './ReajusteLeadForm.svelte';
import type { CampaignLanding as CampaignLandingData } from '../../lib/campaign-landings';

interface Props {
  landing: CampaignLandingData;
}

const { landing } = Astro.props;
const landingId = 'b2b-custos-reajuste';
const thesis = 'renovacao-como-decisao-empresarial';
---

<BaseLayout
  title={landing.metaTitle}
  description="Antes de aceitar o reajuste do plano de saúde empresarial, revise contrato, uso, cobertura e oportunidades com a leitura técnica da Klout."
  noindex={true}
  smoothScrollDelay={0}
  smoothScrollTouch={true}
>
  <Fragment slot="head">
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = 'klout:experiment:reajuste:v1';
        const validVariants = ['tecnica', 'sensorial'];
        const params = new URLSearchParams(window.location.search);
        const requestedVariant = params.get('variant');
        const isForced = validVariants.includes(requestedVariant);
        let selectedVariant = isForced ? requestedVariant : '';

        if (!selectedVariant) {
          try {
            const storedVariant = window.localStorage.getItem(storageKey);
            if (validVariants.includes(storedVariant)) {
              selectedVariant = storedVariant;
            }
          } catch {
            selectedVariant = '';
          }
        }

        if (!selectedVariant) {
          let bucket = Math.random() < 0.5 ? 0 : 1;
          try {
            const randomValue = new Uint32Array(1);
            window.crypto.getRandomValues(randomValue);
            bucket = randomValue[0] % 2;
          } catch {
            // Math.random remains the non-identifying fallback.
          }

          selectedVariant = bucket === 0 ? 'tecnica' : 'sensorial';

          try {
            window.localStorage.setItem(storageKey, selectedVariant);
          } catch {
            // The assignment still remains stable for the current page view.
          }
        }

        const requiredWidth = Math.max(
          window.innerWidth || 0,
          document.documentElement.clientWidth || 0,
        ) * Math.min(window.devicePixelRatio || 1, 3);
        const assetWidth = requiredWidth <= 640
          ? 640
          : requiredWidth <= 960
            ? 960
            : requiredWidth <= 1280
              ? 1280
              : 1536;
        const heroUrl = '/images/campaign/reajuste-' + selectedVariant + '-hero-' + assetWidth + '.webp';

        root.dataset.reajusteVariant = selectedVariant;
        root.dataset.reajusteForced = isForced ? 'true' : 'false';
        root.dataset.reajusteHero = heroUrl;
        root.style.setProperty('--reajuste-hero-image', 'url("' + heroUrl + '")');

        const preload = document.createElement('link');
        preload.rel = 'preload';
        preload.as = 'image';
        preload.type = 'image/webp';
        preload.href = heroUrl;
        preload.fetchPriority = 'high';
        preload.dataset.reajusteHeroPreload = selectedVariant;
        document.head.appendChild(preload);
      })();
    </script>
    <style is:inline>
      html:not([data-reajuste-variant]) .reajuste-experiment {
        visibility: hidden;
      }
    </style>
  </Fragment>

  <div class="reajuste-experiment">
    <header class="experiment-header" aria-label="Cabeçalho da campanha">
      <div class="experiment-header-inner">
        <a href="/" aria-label="Klout — página inicial">
          <img class="experiment-logo-wordmark" src="/images/logo_simple_light-126.webp" alt="Klout" width="126" height="39" />
          <img class="experiment-logo-shield" src="/images/logo_shield_light_3d-148.webp" alt="" width="148" height="199" />
        </a>
        <p>Saúde corporativa · revisão de contrato</p>
        <a class="experiment-header-privacy" href="/privacidade">Privacidade</a>
      </div>
    </header>

    <main id="main-content">
      <section class="experiment-hero" aria-labelledby="reajuste-title">
        <div
          class="experiment-hero-media"
          role="img"
          aria-label="Consultor da Klout reunido com lideranças de Financeiro e RH para revisar o contrato de saúde da empresa"
        >
          <div class="experiment-hero-shade" aria-hidden="true"></div>
        </div>

        <div class="experiment-shell experiment-hero-content">
          <div class="experiment-hero-copy">
            <p class="experiment-eyebrow">
              <span class="copy-tecnica">Antes da renovação</span>
              <span class="copy-sensorial">Antes do próximo ciclo</span>
            </p>
            <h1 id="reajuste-title">
              <span class="copy-tecnica">Antes do reajuste, convém a leitura do contrato com outros critérios.</span>
              <span class="copy-sensorial">Antes de aceitar o reajuste, vale conversar sobre o que a empresa precisa agora.</span>
            </h1>
            <p class="experiment-hero-description">
              <span class="copy-tecnica">A Klout revisa necessidades, cobertura, utilização e investimento antes de a empresa decidir o próximo ciclo.</span>
              <span class="copy-sensorial">A Klout aproxima Financeiro e RH de uma leitura clara do contrato, para avaliar custos, cobertura e oportunidades com mais tranquilidade.</span>
            </p>
            <a
              href="#diagnostico"
              class="experiment-primary-cta"
              data-reajuste-cta
              data-cta-location="hero"
            >
              <span class="copy-tecnica">Revisar meu contrato</span>
              <span class="copy-sensorial">Conversar com a Klout</span>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 14 0m-6-6 6 6-6 6" /></svg>
            </a>
            <p class="experiment-hero-note">Diagnóstico inicial gratuito e sem compromisso.</p>
          </div>

          <aside class="experiment-hero-card" aria-label="Escopo da primeira leitura">
            <p>
              <span class="copy-tecnica">Leitura inicial</span>
              <span class="copy-sensorial">Uma conversa para organizar</span>
            </p>
            <ul>
              <li>Apólice vigente</li>
              <li>Uso e prioridades</li>
              <li>Investimento e rede</li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="experiment-section problem-section" aria-labelledby="problem-title">
        <div class="experiment-shell">
          <div class="section-heading problem-heading">
            <p class="section-kicker">O ponto de partida</p>
            <h2 id="problem-title">
              <span class="copy-tecnica">Quando a renovação vira manutenção, o aumento parece a única decisão disponível.</span>
              <span class="copy-sensorial">Receber um reajuste sem uma nova leitura pesa no orçamento e deixa a empresa sem voz.</span>
            </h2>
            <p>
              <span>O contrato prossegue com preço atualizado, mas desconsiderando possíveis mudanças no período, como necessidades, cobertura e utilização, enquanto Financeiro e RH recebem o impacto sem critérios suficientes para discutir o próximo ciclo.</span>
            </p>
          </div>

          <div class="problem-list">
            <article>
              <span>01</span>
              <h3>Preço isolado</h3>
              <p>O reajuste chega como um percentual, sem relacionar o aumento àquilo que a empresa e os funcionários utilizam.</p>
            </article>
            <article>
              <span>02</span>
              <h3>Contrato desatualizado</h3>
              <p>Rede, regras e desenho do benefício permanecem iguais mesmo quando a equipe, o orçamento e as prioridades já mudaram.</p>
            </article>
            <article>
              <span>03</span>
              <h3>Decisão com pouca margem</h3>
              <p>Quanto mais tarde começa a revisão, menor tende a ser o espaço para comparar condições e planejar uma eventual migração.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="experiment-section mechanism-section" aria-labelledby="mechanism-title">
        <div class="experiment-shell mechanism-layout">
          <div class="mechanism-intro">
            <h2 id="mechanism-title">A sua relação com o plano pode estar limitada ao operacional.</h2>
            <p>No cotidiano, essa relação é ocupada por inclusões, exclusões, autorizações, boletos e dúvidas dos beneficiários. Quando ela se torna o único eixo da corretagem, mudanças na empresa, no uso e no mercado deixam de orientar decisões sobre o reajuste contratual.</p>
          </div>

          <picture class="mechanism-portrait">
            <img
              src="/images/campaign/reajuste-operacional-portrait-864.webp"
              srcset="/images/campaign/reajuste-operacional-portrait-640.webp 640w, /images/campaign/reajuste-operacional-portrait-864.webp 864w"
              sizes="(max-width: 900px) calc(100vw - 2.2rem), min(38vw, 34rem)"
              width="864"
              height="1600"
              loading="lazy"
              decoding="async"
              alt="Consultora conversa com lideranças de Financeiro e RH em um escritório em São Paulo"
            />
          </picture>

          <div class="mechanism-effects">
            <h3>O efeito acumulado</h3>

            <div class="effect-accordion">
              <details name="reajuste-effects">
                <summary>
                  <span class="effect-index">01</span>
                  <span>As informações permanecem fragmentadas</span>
                  <span class="effect-toggle" aria-hidden="true"></span>
                </summary>
                <div class="effect-panel">
                  <p>Financeiro acompanha custo. RH recebe reclamações, dúvidas e pedidos. A operadora concentra dados de utilização. Sem uma leitura conjunta, cada área enxerga apenas uma parte do contrato.</p>
                </div>
              </details>
              <details name="reajuste-effects">
                <summary>
                  <span class="effect-index">02</span>
                  <span>A revisão começa depois do índice</span>
                  <span class="effect-toggle" aria-hidden="true"></span>
                </summary>
                <div class="effect-panel">
                  <p>Quando a análise começa com a carta de reajuste, o prazo já trabalha contra a empresa. Rede, regras, cotações, comunicação e uma eventual migração passam a disputar poucas semanas.</p>
                </div>
              </details>
              <details name="reajuste-effects">
                <summary>
                  <span class="effect-index">03</span>
                  <span>O desenho perde aderência</span>
                  <span class="effect-toggle" aria-hidden="true"></span>
                </summary>
                <div class="effect-panel">
                  <p>Admissões, desligamentos, faixas etárias, cidades, coparticipação e padrões de uso alteram o risco e a percepção do benefício. O plano pode permanecer estável na operação enquanto perde aderência.</p>
                </div>
              </details>
              <details name="reajuste-effects">
                <summary>
                  <span class="effect-index">04</span>
                  <span>A dependência cresce</span>
                  <span class="effect-toggle" aria-hidden="true"></span>
                </summary>
                <div class="effect-panel">
                  <p>Histórico, decisões e regras ficam dispersos entre áreas e fornecedores. Mudar de caminho exige reconstruir informação sob pressão, o que favorece a renovação por inércia.</p>
                </div>
              </details>
            </div>
          </div>
        </div>
      </section>

      <div class="success-story-challenge-stack" data-challenge-stack>
        <div class="success-story-challenge-pin">
      <section class="experiment-section reading-section success-story-challenge-layer success-story-challenge-layer--reading" aria-labelledby="reading-title">
        <div class="experiment-shell reading-layout">
          <div class="reading-intro">
            <h2 id="reading-title">O efeito acumulado é grande, porém reversível.</h2>
            <p>A direção deve se basear em uma análise técnica e contextual que combine quatro frentes.</p>
          </div>

          <div class="reading-visual">
            <p class="reading-mobile-hint" id="reading-mobile-hint">
              <span class="reading-mobile-hint-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" /></svg></span>
              <span>Toque em uma frente para conhecer a análise.</span>
            </p>

            <div class="reading-wheel" aria-label="As quatro frentes da leitura técnica">
              <article class="reading-front">
                <span>01</span>
                <h3>Empresa</h3>
                <p>Financeiro e RH devem ser ouvidos a fim de que a leitura compreenda orçamento, composição da equipe, prioridades e uso real do benefício.</p>
                <button class="reading-front-trigger" type="button" data-reading-front-open aria-haspopup="dialog" aria-controls="reading-detail-dialog" aria-describedby="reading-mobile-hint" aria-label="Ver detalhes sobre Empresa"></button>
              </article>
              <article class="reading-front">
                <span>02</span>
                <h3>Apólice</h3>
                <p>Regras, custos, rede, utilização, coparticipação e pontos que condicionem a renovação ou eventuais mudanças precisam de análise cuidadosa.</p>
                <button class="reading-front-trigger" type="button" data-reading-front-open aria-haspopup="dialog" aria-controls="reading-detail-dialog" aria-describedby="reading-mobile-hint" aria-label="Ver detalhes sobre Apólice">
                  <span class="reading-front-action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" /></svg></span>
                </button>
              </article>
              <article class="reading-front">
                <span>03</span>
                <h3>Parceiros</h3>
                <p>A qualidade da rede de parceiros influencia a disponibilidade de condições e oportunidades mais vantajosas para a empresa.</p>
                <button class="reading-front-trigger" type="button" data-reading-front-open aria-haspopup="dialog" aria-controls="reading-detail-dialog" aria-describedby="reading-mobile-hint" aria-label="Ver detalhes sobre Parceiros">
                  <span class="reading-front-action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" /></svg></span>
                </button>
              </article>
              <article class="reading-front">
                <span>04</span>
                <h3>Oportunidades</h3>
                <p>Redução de custos, aderência, otimização de investimento, entre outros benefícios que podem resultar em um contrato melhor do que o reajuste programado.</p>
                <button class="reading-front-trigger" type="button" data-reading-front-open aria-haspopup="dialog" aria-controls="reading-detail-dialog" aria-describedby="reading-mobile-hint" aria-label="Ver detalhes sobre Oportunidades">
                  <span class="reading-front-action-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6" /></svg></span>
                </button>
              </article>
            </div>

            <dialog class="reading-dialog" id="reading-detail-dialog" data-reading-dialog aria-labelledby="reading-dialog-title" aria-describedby="reading-dialog-description">
              <div class="reading-dialog-panel" data-reading-dialog-panel data-lenis-prevent>
                <header class="reading-dialog-header">
                  <p><span data-reading-dialog-index>01</span><span aria-hidden="true"> / 04</span></p>
                  <button class="reading-dialog-close" type="button" data-reading-dialog-close aria-label="Fechar detalhes">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" /></svg>
                  </button>
                </header>

                <div class="reading-dialog-content">
                  <button class="reading-dialog-nav reading-dialog-previous" type="button" data-reading-dialog-previous aria-label="Ver frente anterior: Oportunidades">
                    <span class="reading-dialog-chevron" aria-hidden="true">&#8249;</span>
                  </button>
                  <div class="reading-dialog-copy" aria-live="polite" aria-atomic="true">
                    <h3 id="reading-dialog-title" data-reading-dialog-title>Empresa</h3>
                    <p id="reading-dialog-description" data-reading-dialog-description>Financeiro e RH devem ser ouvidos a fim de que a leitura compreenda orçamento, composição da equipe, prioridades e uso real do benefício.</p>
                  </div>
                  <button class="reading-dialog-nav reading-dialog-next" type="button" data-reading-dialog-next aria-label="Ver próxima frente: Apólice">
                    <span class="reading-dialog-chevron" aria-hidden="true">&#8250;</span>
                  </button>
                </div>
              </div>
            </dialog>

            <ol class="reading-mobile-notes" data-lenis-prevent aria-label="Descrição das quatro frentes">
              <li><strong>Empresa</strong><p>Financeiro e RH devem ser ouvidos a fim de que a leitura compreenda orçamento, composição da equipe, prioridades e uso real do benefício.</p></li>
              <li><strong>Apólice</strong><p>Regras, custos, rede, utilização, coparticipação e pontos que condicionem a renovação ou eventuais mudanças precisam de análise cuidadosa.</p></li>
              <li><strong>Parceiros</strong><p>A qualidade da rede de parceiros influencia a disponibilidade de condições e oportunidades mais vantajosas para a empresa.</p></li>
              <li><strong>Oportunidades</strong><p>Redução de custos, aderência, otimização de investimento, entre outros benefícios que podem resultar em um contrato melhor do que o reajuste programado.</p></li>
            </ol>
          </div>
        </div>
      </section>

      <section class="experiment-section benefits-section success-story-challenge-layer success-story-challenge-layer--benefits" aria-labelledby="benefits-title">
        <div class="experiment-shell">
          <div class="section-heading benefits-heading">
            <p class="section-kicker">Resultado esperado</p>
            <h2 id="benefits-title">Investimento ligado a benefícios relevantes e bem aproveitados pela equipe.</h2>
            <p>Com critérios organizados, Financeiro e RH ganham confiança para comparar, alívio para conduzir a renovação sem improviso e controle sobre prazos e alternativas. Essa clareza reduz a exposição à renovação automática, à dependência operacional e a uma migração iniciada tarde.</p>
          </div>

          <div class="benefit-grid">
            <article>
              <span>01</span>
              <h3>Oportunidades de custo</h3>
              <p>Identificação de pontos de negociação ou alternativas que podem reduzir o investimento total.</p>
            </article>
            <article>
              <span>02</span>
              <h3>Previsibilidade</h3>
              <p>Leitura de regras, cenários e impactos para planejar o benefício com antecedência.</p>
            </article>
            <article>
              <span>03</span>
              <h3>Aderência atual</h3>
              <p>Rede e desenho compatíveis com as necessidades atuais da empresa e das pessoas.</p>
            </article>
            <article>
              <span>04</span>
              <h3>Melhor aproveitamento</h3>
              <p>Mais clareza sobre aquilo que o contrato entrega e como o benefício é utilizado.</p>
            </article>
          </div>

        </div>
      </section>

        </div>
      </div>

      <section class="experiment-section form-section" aria-label="Formulário e formas de atendimento">
        <div class="experiment-shell form-moment">
          <aside class="attendance-strip" aria-label="Formas de atendimento para o diagnóstico inicial">
            <div class="attendance-strip-intro">
              <p class="section-kicker">Formas de atendimento</p>
              <p>A empresa escolhe como iniciar a leitura. O formato acompanha a agenda de Financeiro e RH.</p>
            </div>

            <ul>
              <li>
                <span>01</span>
                <div>
                  <strong>Enviar documentos</strong>
                  <p>Apólice e informações essenciais.</p>
                </div>
              </li>
              <li>
                <span>02</span>
                <div>
                  <strong>Receber um consultor</strong>
                  <p>Na sede da empresa, com horário combinado.</p>
                </div>
              </li>
              <li>
                <span>03</span>
                <div>
                  <strong>Visitar a Klout</strong>
                  <p>R. da Quitanda, 96 · Centro Histórico de São Paulo · São Paulo - SP · 01012-010.</p>
                </div>
              </li>
            </ul>
          </aside>

          <ReajusteLeadForm client:load landingId={landingId} thesis={thesis} />
        </div>
      </section>
    </main>

    <footer class="experiment-footer">
      <div class="experiment-shell experiment-footer-inner">
        <img src="/images/logo_simple_light-126.webp" alt="Klout" width="126" height="39" loading="lazy" />
        <p>Klout Corretora de Seguros LTDA · CNPJ 60.772.160/0001-80</p>
        <nav aria-label="Links legais">
          <a href="/privacidade">Privacidade</a>
          <a href="/cookies">Cookies</a>
          <a href="/termos">Termos</a>
        </nav>
      </div>
    </footer>
  </div>

  <script is:inline define:vars={{ landingId, thesis }}>
    (() => {
      const root = document.documentElement;
      const variantSlug = root.dataset.reajusteVariant === 'sensorial' ? 'sensorial' : 'tecnica';
      const variantId = variantSlug === 'sensorial' ? 'reajuste-sensorial' : 'reajuste-tecnica';
      const forced = root.dataset.reajusteForced === 'true';

      window.dataLayer = window.dataLayer || [];

      function track(eventName, details) {
        window.dataLayer.push({
          event: eventName,
          landing_id: landingId,
          variant_id: variantId,
          thesis,
          experiment_forced: forced,
          experiment_override: forced ? variantSlug : '',
          ...(details || {}),
        });
      }

      window.__kloutReajusteTrack = track;

      track('landing_variant_view', {
        hero_asset: root.dataset.reajusteHero || '',
      });

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element
          ? event.target.closest('[data-reajuste-cta]')
          : null;
        if (!(target instanceof HTMLElement)) return;

        const selectedCopy = target.querySelector('.copy-' + variantSlug);
        track('cta_click', {
          cta_location: target.dataset.ctaLocation || 'unknown',
          cta_label: ((selectedCopy && selectedCopy.textContent) || target.textContent || '').replace(/\s+/g, ' ').trim(),
        });
      }, { capture: true });

      function setupTechnicalHeroMotion() {
        if (variantSlug !== 'tecnica') return;

        const hero = document.querySelector('.experiment-hero');
        if (!(hero instanceof HTMLElement)) return;

        const desktopQuery = window.matchMedia('(min-width: 701px)');
        const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        let frame = 0;
        let listening = false;

        function render() {
          frame = 0;
          const rect = hero.getBoundingClientRect();
          const progress = Math.min(1, Math.max(0, -rect.top / Math.max(1, rect.height)));
          hero.style.setProperty('--technical-hero-parallax', (progress * 18).toFixed(2) + 'px');
        }

        function requestRender() {
          if (frame) return;
          frame = window.requestAnimationFrame(render);
        }

        function configure() {
          if (listening) {
            window.removeEventListener('scroll', requestRender);
            listening = false;
          }
          if (frame) window.cancelAnimationFrame(frame);
          frame = 0;
          hero.style.removeProperty('--technical-hero-parallax');

          if (!desktopQuery.matches || reducedMotionQuery.matches) return;

          window.addEventListener('scroll', requestRender, { passive: true });
          listening = true;
          render();
        }

        desktopQuery.addEventListener?.('change', configure);
        reducedMotionQuery.addEventListener?.('change', configure);
        configure();
      }

      setupTechnicalHeroMotion();

      function setupTechnicalProblemCard() {
        if (variantSlug !== 'tecnica') return;

        const heading = document.querySelector('.problem-heading');
        const card = heading?.querySelector(':scope > p:last-child');
        const cardCopy = card?.querySelector('span');
        if (!(heading instanceof HTMLElement) || !(card instanceof HTMLElement) || !(cardCopy instanceof HTMLElement)) return;

        const desktopQuery = window.matchMedia('(min-width: 981px)');
        const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        let observer;

        function configure() {
          observer?.disconnect();
          card.classList.remove('is-expanded');
          card.style.removeProperty('--problem-card-start-y');

          if (!desktopQuery.matches) return;

          window.requestAnimationFrame(() => {
            const cardStyle = window.getComputedStyle(card);
            const verticalPadding =
              Number.parseFloat(cardStyle.paddingTop) + Number.parseFloat(cardStyle.paddingBottom);
            const copyRange = document.createRange();
            copyRange.selectNodeContents(cardCopy);
            const copyHeight = copyRange.getBoundingClientRect().height;
            const compactHeight = Math.max(176, copyHeight + verticalPadding);
            const headingHeight = Math.max(1, window.innerHeight, heading.getBoundingClientRect().height);
            const startScale = Math.min(.4, Math.max(.16, compactHeight / headingHeight));

            card.style.setProperty('--problem-card-start-y', startScale.toFixed(4));

            if (reducedMotionQuery.matches || !('IntersectionObserver' in window)) {
              card.classList.add('is-expanded');
              return;
            }

            observer = new IntersectionObserver((entries) => {
              if (!entries.some((entry) => entry.isIntersecting && entry.intersectionRatio >= .52)) return;
              card.classList.add('is-expanded');
              observer?.disconnect();
            }, { threshold: [.35, .52, .7] });

            observer.observe(heading);
          });
        }

        desktopQuery.addEventListener?.('change', configure);
        reducedMotionQuery.addEventListener?.('change', configure);
        configure();
      }

      setupTechnicalProblemCard();

      function setupSuccessStoryChallengeStack() {
        const stack = document.querySelector('[data-challenge-stack]');
        if (!(stack instanceof HTMLElement)) return;

        let frame = 0;
        let resizeFrame = 0;
        let stackStart = 0;
        let viewportHeight = Math.max(1, window.innerHeight);
        let newLayerStart = 0;
        let totalScrollDistance = viewportHeight;

        const clamp = (value, minimum, maximum) => Math.min(maximum, Math.max(minimum, value));

        function render() {
          frame = 0;
          const current = clamp(window.scrollY - stackStart, 0, totalScrollDistance);
          const progress = clamp((current - newLayerStart) / viewportHeight, 0, 1);
          stack.style.setProperty('--benefits-section-y', ((1 - progress) * 100).toFixed(4) + '%');
        }

        function requestRender() {
          if (frame) return;
          frame = window.requestAnimationFrame(render);
        }

        function measure() {
          resizeFrame = 0;
          viewportHeight = Math.max(1, window.innerHeight);

          const previousLayerDistance = 0;
          const newLayerDistance = viewportHeight;
          newLayerStart = previousLayerDistance;
          totalScrollDistance = previousLayerDistance + newLayerDistance;

          stack.style.setProperty(
            '--challenge-stack-height',
            (viewportHeight + totalScrollDistance).toFixed(2) + 'px',
          );

          stackStart = stack.getBoundingClientRect().top + window.scrollY;
          render();
        }

        function requestMeasure() {
          if (resizeFrame) return;
          resizeFrame = window.requestAnimationFrame(measure);
        }

        window.addEventListener('scroll', requestRender, { passive: true });
        window.addEventListener('resize', requestMeasure, { passive: true });
        window.addEventListener('orientationchange', requestMeasure, { passive: true });
        window.visualViewport?.addEventListener('resize', requestMeasure, { passive: true });
        document.fonts?.ready.then(requestMeasure);
        measure();
      }

      setupSuccessStoryChallengeStack();

      function setupReadingDialog() {
        const visual = document.querySelector('.reading-visual');
        const dialog = visual?.querySelector('[data-reading-dialog]');
        const panel = dialog?.querySelector('[data-reading-dialog-panel]');
        const copy = dialog?.querySelector('.reading-dialog-copy');
        const closeButton = dialog?.querySelector('[data-reading-dialog-close]');
        const previousButton = dialog?.querySelector('[data-reading-dialog-previous]');
        const nextButton = dialog?.querySelector('[data-reading-dialog-next]');
        const indexNode = dialog?.querySelector('[data-reading-dialog-index]');
        const titleNode = dialog?.querySelector('[data-reading-dialog-title]');
        const descriptionNode = dialog?.querySelector('[data-reading-dialog-description]');
        const triggers = visual
          ? Array.from(visual.querySelectorAll('[data-reading-front-open]'))
          : [];

        if (
          !(visual instanceof HTMLElement)
          || !(dialog instanceof HTMLElement)
          || typeof dialog.showModal !== 'function'
          || typeof dialog.close !== 'function'
          || !(panel instanceof HTMLElement)
          || !(copy instanceof HTMLElement)
          || !(closeButton instanceof HTMLElement)
          || !(previousButton instanceof HTMLElement)
          || !(nextButton instanceof HTMLElement)
          || !(indexNode instanceof HTMLElement)
          || !(titleNode instanceof HTMLElement)
          || !(descriptionNode instanceof HTMLElement)
          || triggers.length === 0
        ) return;

        const fronts = triggers.map((trigger) => {
          const front = trigger.closest('.reading-front');
          const title = front?.querySelector('h3')?.textContent?.trim() || '';
          const description = front?.querySelector('p')?.textContent?.trim() || '';
          return { trigger, title, description };
        });

        if (fronts.some((front) => !front.title || !front.description)) return;

        const mobileQuery = window.matchMedia(
          '(max-width: 700px), (min-width: 701px) and (max-width: 1100px) and (max-height: 620px)',
        );
        const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        let activeIndex = 0;
        let lastTrigger = null;
        let closing = false;

        function updateFront(index, animate) {
          activeIndex = (index + fronts.length) % fronts.length;
          const activeFront = fronts[activeIndex];
          const previousFront = fronts[(activeIndex - 1 + fronts.length) % fronts.length];
          const nextFront = fronts[(activeIndex + 1) % fronts.length];

          indexNode.textContent = String(activeIndex + 1).padStart(2, '0');
          titleNode.textContent = activeFront.title;
          descriptionNode.textContent = activeFront.description;
          previousButton.setAttribute('aria-label', 'Ver frente anterior: ' + previousFront.title);
          nextButton.setAttribute('aria-label', 'Ver próxima frente: ' + nextFront.title);

          if (animate && !reducedMotionQuery.matches && typeof copy.animate === 'function') {
            copy.getAnimations().forEach((animation) => animation.cancel());
            copy.animate([
              { opacity: .2, transform: 'translate3d(.45rem, 0, 0)' },
              { opacity: 1, transform: 'translate3d(0, 0, 0)' },
            ], {
              duration: 280,
              easing: 'cubic-bezier(.22, 1, .36, 1)',
            });
          }
        }

        function openFront(index, trigger) {
          if (!mobileQuery.matches || dialog.open) return;
          lastTrigger = trigger;
          updateFront(index, false);
          dialog.showModal();
          track('reading_front_open', {
            front_position: index + 1,
            front_title: fronts[index].title,
          });
        }

        function finishClose(reason) {
          closing = false;
          if (dialog.open) dialog.close(reason);
        }

        function requestClose(reason) {
          if (!dialog.open || closing) return;

          if (reducedMotionQuery.matches || typeof panel.animate !== 'function') {
            finishClose(reason);
            return;
          }

          closing = true;
          const animation = panel.animate([
            { opacity: 1, transform: 'translate3d(0, 0, 0)' },
            { opacity: 0, transform: 'translate3d(0, 1rem, 0)' },
          ], {
            duration: 220,
            easing: 'cubic-bezier(.4, 0, 1, 1)',
          });

          animation.finished
            .catch(() => {})
            .finally(() => finishClose(reason));
        }

        triggers.forEach((trigger, index) => {
          trigger.addEventListener('click', () => openFront(index, trigger));
        });

        closeButton.addEventListener('click', () => requestClose('close-button'));

        previousButton.addEventListener('click', () => {
          updateFront(activeIndex - 1, true);
          track('reading_front_previous', {
            front_position: activeIndex + 1,
            front_title: fronts[activeIndex].title,
          });
        });

        nextButton.addEventListener('click', () => {
          updateFront(activeIndex + 1, true);
          track('reading_front_next', {
            front_position: activeIndex + 1,
            front_title: fronts[activeIndex].title,
          });
        });

        dialog.addEventListener('click', (event) => {
          if (event.target === dialog) requestClose('backdrop');
        });

        dialog.addEventListener('cancel', (event) => {
          event.preventDefault();
          requestClose('escape');
        });

        dialog.addEventListener('close', () => {
          closing = false;
          lastTrigger?.focus({ preventScroll: true });
        });

        mobileQuery.addEventListener?.('change', (event) => {
          if (!event.matches && dialog.open) finishClose('viewport-change');
        });

        visual.classList.add('is-dialog-ready');
      }

      setupReadingDialog();

    })();
  </script>
</BaseLayout>

