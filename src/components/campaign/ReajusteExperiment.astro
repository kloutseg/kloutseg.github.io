    text-align: center;
  }

  .reading-dialog-copy h3 {
    max-width: 13ch;
    margin: 0 auto;
    font: 400 clamp(2rem, 9vw, 2.75rem)/1.02 'IBM Plex Serif', serif;
    letter-spacing: -.04em;
