  }

  .reading-dialog-copy p {
    max-width: 32ch;
    margin: 1.15rem auto 0;
    color: var(--muted);
    font: 400 .98rem/1.62 'Proxima Nova', sans-serif;
  }

  .reading-dialog-nav {
    width: 3rem;
    height: 4rem;
    padding: 0;
    display: inline-grid;
    place-items: center;
    border: 0;
    border-radius: 0;
    -webkit-appearance: none;
    appearance: none;
    background: none;
    color: var(--accent);
    cursor: pointer;
    opacity: .82;
    touch-action: manipulation;
    transition: opacity .2s ease, transform .2s ease;
