---
const gtmId = import.meta.env.PUBLIC_GTM_ID;
const cloudflareWebAnalyticsToken = 'bb8fbce41322499481af3f732f4c5c1f';
---

<script is:inline>
  (() => {
    const STORAGE_KEY = 'klout:cookie-consent';
    const CONSENT_VERSION = '2026-05-14';
    const DEFAULT_STATE = {
      necessary: true,
      analytics: false,
      experience: false,
      marketing: false,
    };

    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function gtag(){ window.dataLayer.push(arguments); };
    window.gtag('consent', 'default', {
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      analytics_storage: 'denied',
      functionality_storage: 'granted',
      security_storage: 'granted',
    });

    function readConsent() {
      try {
        const raw = window.localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        if (!parsed || parsed.version !== CONSENT_VERSION || !parsed.preferences) return null;
        return {
          ...DEFAULT_STATE,
          ...parsed.preferences,
          necessary: true,
        };
      } catch {
        return null;
      }
    }

    function writeConsent(preferences) {
      const normalized = {
        ...DEFAULT_STATE,
        ...preferences,
        necessary: true,
      };

      window.localStorage.setItem(STORAGE_KEY, JSON.stringify({
        version: CONSENT_VERSION,
        savedAt: new Date().toISOString(),
        preferences: normalized,
      }));

      return normalized;
    }

    function updateGoogleConsent(preferences) {
      window.gtag('consent', 'update', {
        analytics_storage: preferences.analytics ? 'granted' : 'denied',
        ad_storage: preferences.marketing ? 'granted' : 'denied',
        ad_user_data: preferences.marketing ? 'granted' : 'denied',
        ad_personalization: preferences.marketing ? 'granted' : 'denied',
        functionality_storage: 'granted',
        security_storage: 'granted',
      });
    }

    function applyConsent(preferences) {
      updateGoogleConsent(preferences);
      window.dispatchEvent(new CustomEvent('klout:consent-updated', {
        detail: { preferences },
      }));
    }

    window.KloutConsent = {
      read: readConsent,
      save(preferences) {
        const saved = writeConsent(preferences);
        applyConsent(saved);
        return saved;
      },
      openPreferences() {
        window.dispatchEvent(new CustomEvent('klout:open-cookie-preferences'));
      },
      hasConsent(category) {
        const current = readConsent();
        return !!current?.[category];
      },
    };

    const storedConsent = readConsent();
    if (storedConsent) applyConsent(storedConsent);
  })();
</script>

{gtmId && (
  <script is:inline define:vars={{ gtmId }}>
    (() => {
      let loaded = false;

      function loadGtm() {
        if (loaded) return;
        const consent = window.KloutConsent?.read?.();
        if (!consent || (!consent.analytics && !consent.experience && !consent.marketing)) return;

        loaded = true;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

        const script = document.createElement('script');
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtm.js?id=${encodeURIComponent(gtmId)}`;
        document.head.appendChild(script);
      }

      loadGtm();
      window.addEventListener('klout:consent-updated', loadGtm);
    })();
  </script>
)}

<script is:inline define:vars={{ cloudflareWebAnalyticsToken }}>
  (() => {
    let loaded = false;

    function loadCloudflareWebAnalytics() {
      if (loaded) return;
      const consent = window.KloutConsent?.read?.();
      if (!consent?.analytics) return;
      if (document.querySelector('script[data-cf-beacon]')) {
        loaded = true;
        return;
      }

      loaded = true;
      const script = document.createElement('script');
      script.defer = true;
      script.src = 'https://static.cloudflareinsights.com/beacon.min.js';
      script.dataset.cfBeacon = JSON.stringify({ token: cloudflareWebAnalyticsToken });
      document.head.appendChild(script);
    }

    loadCloudflareWebAnalytics();
    window.addEventListener('klout:consent-updated', loadCloudflareWebAnalytics);
  })();
</script>

<div class="cookie-consent" data-cookie-consent hidden>
  <div class="cookie-consent__panel" role="region" aria-labelledby="cookie-consent-title" aria-describedby="cookie-consent-description">
    <div class="cookie-consent__copy">
      <h2 id="cookie-consent-title">Cookies e privacidade</h2>
      <p id="cookie-consent-description">
        Usamos cookies essenciais e, com sua permissão, dados de navegação para melhorar sua experiência.
      </p>
    </div>

    <div class="cookie-consent__actions">
      <button type="button" class="cookie-consent__button cookie-consent__button--primary" data-consent-accept>
        Aceitar
      </button>
      <button type="button" class="cookie-consent__button cookie-consent__button--ghost" data-consent-configure>
        Configurar
      </button>
      <button type="button" class="cookie-consent__button cookie-consent__button--text" data-consent-reject>
        Rejeitar
      </button>
    </div>
  </div>
</div>

<div class="cookie-modal" data-cookie-modal hidden>
  <div class="cookie-modal__backdrop" data-consent-close></div>
  <div class="cookie-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="cookie-modal-title">
    <div class="cookie-modal__header">
      <div>
        <p class="cookie-consent__kicker">Preferências</p>
        <h2 id="cookie-modal-title">Gerenciar consentimento</h2>
      </div>
      <button type="button" class="cookie-modal__close" data-consent-close aria-label="Fechar preferências">
        &times;
      </button>
    </div>

    <div class="cookie-modal__options">
      <label class="cookie-option cookie-option--locked">
        <span>
          <strong>Necessários</strong>
          <small>Essenciais para segurança, funcionamento do site, formulário e preferências de consentimento.</small>
        </span>
        <span class="cookie-switch cookie-switch--locked" aria-hidden="true"></span>
        <input type="checkbox" checked disabled />
      </label>

      <label class="cookie-option">
        <span>
          <strong>Analíticos</strong>
          <small>Medem audiência e desempenho, como GA4, Matomo ou relatórios conectados.</small>
        </span>
        <span class="cookie-switch" aria-hidden="true"></span>
        <input type="checkbox" data-consent-category="analytics" />
      </label>

      <label class="cookie-option">
        <span>
          <strong>Experiência e comportamento</strong>
          <small>Mapas de calor, gravações de sessão e melhoria de usabilidade, como Clarity ou Hotjar.</small>
        </span>
        <span class="cookie-switch" aria-hidden="true"></span>
        <input type="checkbox" data-consent-category="experience" />
      </label>

      <label class="cookie-option">
        <span>
          <strong>Marketing</strong>
          <small>Mensuração de campanhas, remarketing e personalização de anúncios.</small>
        </span>
        <span class="cookie-switch" aria-hidden="true"></span>
        <input type="checkbox" data-consent-category="marketing" />
      </label>
    </div>

    <div class="cookie-modal__footer">
      <a href="/cookies" class="cookie-modal__link">Ver política de cookies</a>
      <div class="cookie-modal__buttons">
        <button type="button" class="cookie-consent__button" data-consent-save>
          Salvar preferências
        </button>
        <button type="button" class="cookie-consent__button cookie-consent__button--primary" data-consent-accept>
          Aceitar todos
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const banner = document.querySelector('[data-cookie-consent]');
    const modal = document.querySelector('[data-cookie-modal]');
    if (!(banner instanceof HTMLElement) || !(modal instanceof HTMLElement)) return;

    const categories = Array.from(document.querySelectorAll('[data-consent-category]'));

    function currentPreferences() {
      return window.KloutConsent?.read?.() || {
        necessary: true,
        analytics: false,
        experience: false,
        marketing: false,
      };
    }

    function syncInputs(preferences = currentPreferences()) {
      categories.forEach((input) => {
        if (!(input instanceof HTMLInputElement)) return;
        input.checked = !!preferences[input.dataset.consentCategory];
      });
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    function closeBanner() {
      banner.hidden = true;
    }

    function openModal() {
      syncInputs();
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      const firstInput = modal.querySelector('[data-consent-category]');
      if (firstInput instanceof HTMLElement) firstInput.focus();
    }

    function save(preferences) {
      window.KloutConsent?.save?.(preferences);
      closeBanner();
      closeModal();
    }

    function saveFromInputs() {
      const preferences = { necessary: true };
      categories.forEach((input) => {
        if (!(input instanceof HTMLInputElement)) return;
        preferences[input.dataset.consentCategory] = input.checked;
      });
      save(preferences);
    }

    function acceptAll() {
      save({
        necessary: true,
        analytics: true,
        experience: true,
        marketing: true,
      });
    }

    function rejectOptional() {
      save({
        necessary: true,
        analytics: false,
        experience: false,
        marketing: false,
      });
    }

    if (!window.KloutConsent?.read?.()) {
      banner.hidden = false;
    }

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      if (target.closest('[data-consent-accept]')) {
        acceptAll();
        return;
      }

      if (target.closest('[data-consent-reject]')) {
        rejectOptional();
        return;
      }

      if (target.closest('[data-consent-configure]') || target.closest('[data-open-cookie-preferences]')) {
        event.preventDefault();
        openModal();
        return;
      }

      if (target.closest('[data-consent-save]')) {
        saveFromInputs();
        return;
      }

      if (target.closest('[data-consent-close]')) {
        closeModal();
      }
    });

    window.addEventListener('klout:open-cookie-preferences', openModal);
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hidden) closeModal();
    });
  })();
</script>

<style>
  .cookie-consent,
  .cookie-modal {
    font-family: var(--font-sans);
  }

  .cookie-consent[hidden],
  .cookie-modal[hidden] {
    display: none;
  }

  .cookie-consent {
    position: fixed;
    right: auto;
    bottom: 1.2rem;
    left: 1.2rem;
    z-index: 30000;
    display: flex;
    justify-content: flex-start;
    pointer-events: none;
  }

  .cookie-consent__panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 7.8rem;
    align-items: center;
    gap: 0.82rem;
    width: min(calc(100vw - 2.4rem), 28rem);
    padding: 0.82rem;
    border: 1px solid hsla(42, 20%, 74%, 0.3);
    border-radius: 8px;
    background:
      linear-gradient(180deg, hsla(42, 24%, 99%, 0.92), hsla(42, 18%, 96%, 0.9));
    color: hsl(214, 40%, 15%);
    box-shadow:
      0 10px 28px hsla(214, 28%, 12%, 0.12),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.72);
    backdrop-filter: blur(14px) saturate(1.04);
    pointer-events: auto;
  }

  .cookie-consent__kicker {
    margin: 0 0 0.12rem;
    color: hsla(42, 24%, 38%, 0.76);
    font-size: 0.56rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cookie-consent h2,
  .cookie-modal h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1.12;
    color: hsl(214, 28%, 18%);
  }

  .cookie-consent p {
    margin: 0.26rem 0 0;
    max-width: 20rem;
    color: hsl(214, 14%, 36%);
    font-size: 0.78rem;
    line-height: 1.42;
  }

  .cookie-consent__actions {
    display: flex;
    align-items: center;
    flex-direction: column;
    align-items: stretch;
    gap: 0.28rem;
    justify-content: center;
  }

  .cookie-consent__button {
    min-height: 31px;
    width: 100%;
    padding: 0.42rem 0.58rem;
    border: 1px solid hsla(214, 18%, 40%, 0.16);
    border-radius: 8px;
    background: hsla(0, 0%, 100%, 0.52);
    color: hsl(214, 34%, 20%);
    font: inherit;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    cursor: pointer;
    box-shadow: inset 0 1px 0 hsla(0, 0%, 100%, 0.55);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .cookie-consent__button:hover {
    border-color: hsla(42, 34%, 42%, 0.44);
    background: hsla(42, 24%, 99%, 0.86);
    transform: translateY(-1px);
  }

  .cookie-consent__button--primary {
    border-color: hsla(42, 34%, 38%, 0.86);
    background: linear-gradient(135deg, hsl(42, 28%, 43%) 0%, hsl(40, 24%, 32%) 100%);
    color: white;
    box-shadow:
      0 7px 18px hsla(42, 28%, 18%, 0.16),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.14);
  }

  .cookie-consent__button--ghost {
    background: transparent;
    border-color: hsla(214, 18%, 40%, 0.12);
    color: hsl(214, 18%, 32%);
  }

  .cookie-consent__button--text {
    min-height: 26px;
    border-color: transparent;
    background: transparent;
    color: hsl(214, 12%, 42%);
    box-shadow: none;
  }

  .cookie-consent__button--text:hover {
    background: transparent;
    color: hsl(214, 28%, 18%);
    transform: none;
  }

  .cookie-modal {
    position: fixed;
    inset: 0;
    z-index: 30010;
    display: grid;
    place-items: center;
    padding: 1.25rem;
  }

  .cookie-modal__backdrop {
    position: absolute;
    inset: 0;
    background: hsla(214, 38%, 8%, 0.34);
    backdrop-filter: blur(7px);
  }

  .cookie-modal__dialog {
    position: relative;
    width: min(100%, 39rem);
    max-height: min(90vh, 44rem);
    overflow: auto;
    padding: 1.1rem;
    border-radius: 8px;
    border: 1px solid hsla(42, 20%, 78%, 0.46);
    background: hsla(42, 24%, 98%, 0.98);
    color: hsl(214, 40%, 15%);
    box-shadow:
      0 20px 58px hsla(214, 45%, 8%, 0.2),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.78);
  }

  .cookie-modal__header,
  .cookie-modal__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cookie-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid hsla(214, 22%, 34%, 0.18);
    border-radius: 8px;
    background: hsla(0, 0%, 100%, 0.72);
    color: hsl(214, 40%, 15%);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .cookie-modal__options {
    display: grid;
    gap: 0.62rem;
    margin: 1.1rem 0;
  }

  .cookie-option {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 0.86rem;
    border: 1px solid hsla(214, 22%, 34%, 0.11);
    border-radius: 8px;
    background: hsla(0, 0%, 100%, 0.58);
  }

  .cookie-option strong {
    display: block;
    margin-bottom: 0.28rem;
    font-size: 0.92rem;
  }

  .cookie-option small {
    display: block;
    color: hsl(214, 18%, 34%);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .cookie-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .cookie-switch {
    position: relative;
    width: 2rem;
    height: 1.08rem;
    border-radius: 999px;
    background: hsl(214, 14%, 82%);
    box-shadow: inset 0 1px 2px hsla(214, 24%, 18%, 0.16);
    transition: background 0.2s ease;
  }

  .cookie-switch::after {
    content: '';
    position: absolute;
    top: 0.16rem;
    left: 0.16rem;
    width: 0.76rem;
    height: 0.76rem;
    border-radius: 999px;
    background: white;
    box-shadow: 0 1px 3px hsla(214, 24%, 18%, 0.18);
    transition: transform 0.2s ease;
  }

  .cookie-option input:checked + .cookie-switch,
  .cookie-option:has(input:checked) .cookie-switch {
    background: hsl(42, 30%, 44%);
  }

  .cookie-option input:checked + .cookie-switch::after,
  .cookie-option:has(input:checked) .cookie-switch::after {
    transform: translateX(0.92rem);
  }

  .cookie-switch--locked {
    opacity: 0.72;
  }

  .cookie-option--locked {
    background: hsla(214, 22%, 96%, 0.72);
  }

  .cookie-modal__link {
    color: hsl(214, 50%, 24%);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .cookie-modal__buttons {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 768px) {
    .cookie-consent {
      right: 0.75rem;
      bottom: 0.75rem;
      left: 0.75rem;
    }

    .cookie-consent__panel {
      grid-template-columns: 1fr;
      gap: 0.72rem;
      border-radius: 8px;
      padding: 0.82rem;
    }

    .cookie-consent p {
      font-size: 0.78rem;
    }

    .cookie-consent__actions,
    .cookie-modal__footer,
    .cookie-modal__buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .cookie-consent__button {
      width: 100%;
      min-height: 30px;
    }
  }
</style>
